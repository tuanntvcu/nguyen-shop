{{ 'section-altaeron-home.css' | asset_url | stylesheet_tag }}

<section class="altaeron-section altaeron-newsletter" data-section-id="{{ section.id }}">
  <div class="page-width altaeron-newsletter__inner">
    <div>
      <p class="altaeron-eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="altaeron-heading altaeron-heading--section">{{ section.settings.heading }}</h2>
      <div class="altaeron-text">{{ section.settings.text }}</div>
    </div>
    <div class="altaeron-newsletter__form">
      {%- form 'customer', id: 'AltaeronNewsletter', is: 'newsletter-form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <label class="visually-hidden" for="AltaeronNewsletterEmail">{{ section.settings.placeholder }}</label>
        <input
          id="AltaeronNewsletterEmail"
          type="email"
          name="contact[email]"
          value="{{ form.email }}"
          placeholder="{{ section.settings.placeholder }}"
          autocomplete="email"
          autocorrect="off"
          autocapitalize="off"
          required
        >
        <button class="altaeron-button altaeron-button--primary" type="submit" name="commit">
          {{ section.settings.button_label }}
        </button>
      {%- endform -%}
      {%- if section.settings.note != blank -%}
        <div class="altaeron-newsletter__small">{{ section.settings.note }}</div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Altaeron newsletter",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer", "custom.overlay"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "JOIN THE ADVENTURE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "JOIN THE ALTAERON CREW"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Exclusive deals, new product launches, fishing tips, and more.</p>"
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Email placeholder",
      "default": "Enter your email address"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "JOIN NOW"
    },
    {
      "type": "text",
      "id": "note",
      "label": "Small note",
      "default": "No spam. Unsubscribe anytime."
    }
  ],
  "presets": [
    {
      "name": "Altaeron newsletter"
    }
  ]
}
{% endschema %}
