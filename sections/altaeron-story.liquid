{{ 'section-altaeron-home.css' | asset_url | stylesheet_tag }}

<section class="altaeron-section altaeron-story" data-section-id="{{ section.id }}">
  <div class="altaeron-story__media" aria-hidden="true">
    {%- if section.settings.image != blank -%}
      {{
        section.settings.image
        | image_url: width: 2200
        | image_tag:
          loading: 'lazy',
          widths: '750, 1100, 1500, 1800, 2200',
          sizes: '100vw'
      }}
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg altaeron-placeholder' }}
    {%- endif -%}
  </div>
  <div class="altaeron-story__overlay"></div>
  <div class="page-width altaeron-story__inner">
    <div class="altaeron-story__content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="altaeron-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="altaeron-heading altaeron-heading--section">{{ section.settings.heading | escape | newline_to_br }}</h2>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <div class="altaeron-text">{{ section.settings.text }}</div>
      {%- endif -%}
      {%- if section.settings.button_label != blank -%}
        <div class="altaeron-story__button">
          <a
            class="altaeron-button altaeron-button--secondary"
            {% if section.settings.button_link != blank %}
              href="{{ section.settings.button_link }}"
            {% else %}
              role="link" aria-disabled="true"
            {% endif %}
          >
            {{ section.settings.button_label }}
          </a>
        </div>
      {%- endif -%}
      <div class="altaeron-feature-grid">
        {%- for block in section.blocks -%}
          <div class="altaeron-feature" {{ block.shopify_attributes }}>
            <span class="altaeron-icon">{%- render 'icon-check' -%}</span>
            <div>
              <p class="altaeron-feature__title">{{ block.settings.title }}</p>
              <p class="altaeron-feature__text">{{ block.settings.text }}</p>
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Altaeron brand story",
  "tag": "section",
  "class": "section",
  "max_blocks": 3,
  "disabled_on": {
    "groups": ["header", "footer", "custom.overlay"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "OUR PROMISE"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "BUILT FOR ANGLERS.\nDRIVEN BY ADVENTURE."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>At Altaeron, we believe the best gear doesn't just perform - it disappears. So you can stay focused on what matters most.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "PREMIUM QUALITY"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Top-tier materials."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Altaeron brand story",
      "blocks": [
        {
          "type": "feature"
        },
        {
          "type": "feature"
        },
        {
          "type": "feature"
        }
      ]
    }
  ]
}
{% endschema %}
