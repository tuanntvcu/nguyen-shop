{{ 'section-altaeron-home.css' | asset_url | stylesheet_tag }}

<section class="altaeron-section altaeron-categories" data-section-id="{{ section.id }}">
  <div class="page-width">
    <div class="altaeron-categories__grid">
      {%- for block in section.blocks -%}
        <a
          class="altaeron-category"
          {% if block.settings.link != blank %}
            href="{{ block.settings.link }}"
          {% else %}
            role="link" aria-disabled="true"
          {% endif %}
          {{ block.shopify_attributes }}
        >
          <span class="altaeron-category__media" aria-hidden="true">
            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 900
                | image_tag:
                  loading: 'lazy',
                  widths: '320, 480, 640, 800, 900',
                  sizes: '(max-width: 767px) 82vw, 20vw'
              }}
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg altaeron-placeholder' }}
            {%- endif -%}
          </span>
          <span class="altaeron-category__content">
            <span class="altaeron-category__title">{{ block.settings.title }}</span>
            <span class="altaeron-category__text">{{ block.settings.text }}</span>
            <span class="altaeron-category__cta">{{ block.settings.cta }}</span>
          </span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Altaeron category cards",
  "tag": "section",
  "class": "section",
  "max_blocks": 8,
  "disabled_on": {
    "groups": ["header", "footer", "custom.overlay"]
  },
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "POLARIZED SUNGLASSES"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Clarity you can feel."
        },
        {
          "type": "text",
          "id": "cta",
          "label": "CTA",
          "default": "SHOP NOW"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Altaeron category cards",
      "blocks": [
        {
          "type": "category"
        },
        {
          "type": "category"
        },
        {
          "type": "category"
        },
        {
          "type": "category"
        },
        {
          "type": "category"
        }
      ]
    }
  ]
}
{% endschema %}
