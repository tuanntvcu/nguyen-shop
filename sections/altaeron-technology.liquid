{{ 'section-altaeron-home.css' | asset_url | stylesheet_tag }}

<section class="altaeron-section altaeron-tech-section" data-section-id="{{ section.id }}">
  <div class="page-width altaeron-tech-section__inner">
    <div class="altaeron-tech-section__content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="altaeron-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="altaeron-heading altaeron-heading--section">{{ section.settings.heading | escape | newline_to_br }}</h2>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <div class="altaeron-text">{{ section.settings.text }}</div>
      {%- endif -%}
      {%- if section.settings.button_label != blank -%}
        <div class="altaeron-community__actions">
          <a
            class="altaeron-button altaeron-button--secondary"
            {% if section.settings.button_link != blank %}
              href="{{ section.settings.button_link }}"
            {% else %}
              role="link" aria-disabled="true"
            {% endif %}
          >
            {{ section.settings.button_label }}
          </a>
        </div>
      {%- endif -%}
      <div class="altaeron-tech-grid">
        {%- for block in section.blocks -%}
          <div class="altaeron-tech" {{ block.shopify_attributes }}>
            <span class="altaeron-icon">{%- render 'icon-check' -%}</span>
            <div>
              <p class="altaeron-tech__title">{{ block.settings.title }}</p>
              <p class="altaeron-tech__text">{{ block.settings.text }}</p>
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>
    <div class="altaeron-tech-section__media">
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 1400
          | image_tag:
            loading: 'lazy',
            widths: '600, 900, 1200, 1400',
            sizes: '(max-width: 989px) 100vw, 55vw'
        }}
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg altaeron-placeholder' }}
      {%- endif -%}
      {%- if section.settings.badge != blank -%}
        <span class="altaeron-tech-section__badge">{{ section.settings.badge }}</span>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Altaeron technology",
  "tag": "section",
  "class": "section",
  "max_blocks": 4,
  "disabled_on": {
    "groups": ["header", "footer", "custom.overlay"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "POLARIZED LENS TECHNOLOGY"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "ENGINEERED LIGHT.\nNOT JUST DARK."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Our multi-layer TAC lenses cut glare, enhance contrast, and reveal what others miss.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "LEARN MORE"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "badge",
      "label": "Image badge",
      "default": "WITH ALTAERON"
    }
  ],
  "blocks": [
    {
      "type": "tech",
      "name": "Tech point",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "HD CLARITY"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "High definition"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Altaeron technology",
      "blocks": [
        {
          "type": "tech"
        },
        {
          "type": "tech"
        },
        {
          "type": "tech"
        },
        {
          "type": "tech"
        }
      ]
    }
  ]
}
{% endschema %}
