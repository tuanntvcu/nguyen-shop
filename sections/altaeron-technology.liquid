{{ 'section-altaeron-home.css' | asset_url | stylesheet_tag }}

<section class="altaeron-section altaeron-tech-section" data-section-id="{{ section.id }}">
  <div class="page-width altaeron-tech-section__inner">
    <div class="altaeron-tech-section__content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="altaeron-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="altaeron-heading altaeron-heading--section">{{ section.settings.heading | escape | newline_to_br }}</h2>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <div class="altaeron-text">{{ section.settings.text }}</div>
      {%- endif -%}
      {%- if section.settings.button_label != blank -%}
        <div class="altaeron-community__actions">
          <a
            class="altaeron-button altaeron-button--secondary"
            {% if section.settings.button_link != blank %}
              href="{{ section.settings.button_link }}"
            {% else %}
              role="link" aria-disabled="true"
            {% endif %}
          >
            {{ section.settings.button_label }}
          </a>
        </div>
      {%- endif -%}
      <div class="altaeron-tech-grid">
        {%- for block in section.blocks -%}
          <div class="altaeron-tech" {{ block.shopify_attributes }}>
            <span class="altaeron-icon">
              {%- if block.settings.icon != blank -%}
                {{
                  block.settings.icon
                  | image_url: width: 96
                  | image_tag:
                    loading: 'lazy',
                    widths: '48, 72, 96',
                    class: 'altaeron-icon__image',
                    alt: block.settings.title
                }}
              {%- else -%}
                {%- render 'icon-check' -%}
              {%- endif -%}
            </span>
            <div>
              <p class="altaeron-tech__title">{{ block.settings.title }}</p>
              <p class="altaeron-tech__text">{{ block.settings.text }}</p>
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>
    <div class="altaeron-tech-section__media" data-altaeron-compare style="--position: 52%;">
      <div class="altaeron-compare">
        <div class="altaeron-compare__image altaeron-compare__image--before">
          {%- if section.settings.before_image != blank -%}
            {{
              section.settings.before_image
              | image_url: width: 1400
              | image_tag:
                loading: 'lazy',
                widths: '600, 900, 1200, 1400',
                sizes: '(max-width: 989px) 100vw, 58vw'
            }}
          {%- elsif section.settings.image != blank -%}
            {{
              section.settings.image
              | image_url: width: 1400
              | image_tag:
                loading: 'lazy',
                widths: '600, 900, 1200, 1400',
                sizes: '(max-width: 989px) 100vw, 58vw'
            }}
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg altaeron-placeholder' }}
          {%- endif -%}
        </div>
        <div class="altaeron-compare__image altaeron-compare__image--after">
          {%- if section.settings.after_image != blank -%}
            {{
              section.settings.after_image
              | image_url: width: 1400
              | image_tag:
                loading: 'lazy',
                widths: '600, 900, 1200, 1400',
                sizes: '(max-width: 989px) 100vw, 58vw'
            }}
          {%- elsif section.settings.image != blank -%}
            {{
              section.settings.image
              | image_url: width: 1400
              | image_tag:
                loading: 'lazy',
                widths: '600, 900, 1200, 1400',
                sizes: '(max-width: 989px) 100vw, 58vw'
            }}
          {%- else -%}
            {{ 'product-2' | placeholder_svg_tag: 'placeholder-svg altaeron-placeholder' }}
          {%- endif -%}
        </div>
        <span class="altaeron-compare__divider" aria-hidden="true"></span>
        <span class="altaeron-compare__handle" aria-hidden="true"></span>
        <input class="altaeron-compare__range" type="range" min="0" max="100" value="52" aria-label="Compare lens clarity">
        <span class="altaeron-compare__label altaeron-compare__label--before">{{ section.settings.before_label }}</span>
        <span class="altaeron-compare__label altaeron-compare__label--after">{{ section.settings.after_label }}</span>
      </div>
    </div>
  </div>
</section>

<script>
  (() => {
    const section = document.currentScript.previousElementSibling;
    if (!section) return;
    section.querySelectorAll('[data-altaeron-compare]').forEach((compare) => {
      const range = compare.querySelector('.altaeron-compare__range');
      if (!range) return;
      const sync = () => compare.style.setProperty('--position', `${range.value}%`);
      range.addEventListener('input', sync);
      sync();
    });
  })();
</script>

{% schema %}
{
  "name": "Altaeron technology",
  "tag": "section",
  "class": "section",
  "max_blocks": 4,
  "disabled_on": {
    "groups": ["header", "footer", "custom.overlay"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "POLARIZED LENS TECHNOLOGY"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "ENGINEERED LIGHT.\nNOT JUST DARK."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Our multi-layer TAC lenses cut glare, enhance contrast, and reveal what others miss.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "LEARN MORE"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Fallback image"
    },
    {
      "type": "image_picker",
      "id": "before_image",
      "label": "Before image"
    },
    {
      "type": "image_picker",
      "id": "after_image",
      "label": "After image"
    },
    {
      "type": "text",
      "id": "before_label",
      "label": "Before label",
      "default": "WITHOUT ALTAERON"
    },
    {
      "type": "text",
      "id": "after_label",
      "label": "After label",
      "default": "WITH ALTAERON"
    }
  ],
  "blocks": [
    {
      "type": "tech",
      "name": "Tech point",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "HD CLARITY"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "High definition"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Altaeron technology",
      "blocks": [
        {
          "type": "tech"
        },
        {
          "type": "tech"
        },
        {
          "type": "tech"
        },
        {
          "type": "tech"
        }
      ]
    }
  ]
}
{% endschema %}
