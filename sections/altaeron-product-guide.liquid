{%- liquid
  assign product_faqs = product.metafields.custom.product_faqs.value
  assign care_content = product.metafields.custom.care_content
  assign has_fallback = false
  for block in section.blocks
    if block.type == 'faq' and block.settings.question != blank and block.settings.answer != blank
      assign has_fallback = true
      break
    endif
  endfor
  assign has_guide = false
  if product_faqs != blank or care_content != blank or has_fallback
    assign has_guide = true
  endif
-%}

{%- if section.settings.show_section and has_guide -%}
  {{ 'altaeron-product.css' | asset_url | stylesheet_tag }}
  <section id="altaeron-guide" class="altaeron-guide altaeron-surface altaeron-chapter" data-altaeron-chapter="Keeper’s Guide" data-one-open="{{ section.settings.one_open }}" aria-labelledby="AltaeronGuideTitle-{{ section.id }}" style="--altaeron-bg: {{ section.settings.background }}; --altaeron-text: {{ section.settings.text_color }}; --altaeron-accent: {{ section.settings.accent_color }}; --altaeron-muted: {{ section.settings.muted_color }};">
    <header class="altaeron-section-heading">
      <p class="altaeron-kicker">08 / {{ section.settings.eyebrow | escape }}</p>
      <h2 id="AltaeronGuideTitle-{{ section.id }}">{{ section.settings.heading | escape }}</h2>
      {%- if care_content != blank -%}<div class="altaeron-rte">{{ care_content | metafield_tag }}</div>{%- endif -%}
    </header>

    <div class="altaeron-faqs">
      {%- if product_faqs != blank -%}
        {%- for faq in product_faqs -%}
          {%- assign faq_open = false -%}
          {%- if forloop.first and section.settings.open_first -%}{%- assign faq_open = true -%}{%- endif -%}
          <details id="AltaeronFaq-{{ section.id }}-{{ forloop.index }}" class="altaeron-faq" {% if faq_open %}open{% endif %}>
            <summary aria-expanded="{{ faq_open }}" aria-controls="AltaeronFaqAnswer-{{ section.id }}-{{ forloop.index }}"><span>{{ faq.question.value | escape }}</span><span class="altaeron-faq__toggle" aria-hidden="true"></span></summary>
            <div id="AltaeronFaqAnswer-{{ section.id }}-{{ forloop.index }}" class="altaeron-faq__answer altaeron-rte">{{ faq.answer | metafield_tag }}</div>
          </details>
        {%- endfor -%}
      {%- else -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'faq' and block.settings.question != blank and block.settings.answer != blank -%}
            {%- assign faq_open = false -%}
            {%- if forloop.first and section.settings.open_first -%}{%- assign faq_open = true -%}{%- endif -%}
            <details id="AltaeronFaq-{{ section.id }}-{{ block.id }}" class="altaeron-faq" {{ block.shopify_attributes }} {% if faq_open %}open{% endif %}>
              <summary aria-expanded="{{ faq_open }}" aria-controls="AltaeronFaqAnswer-{{ section.id }}-{{ block.id }}"><span>{{ block.settings.question | escape }}</span><span class="altaeron-faq__toggle" aria-hidden="true"></span></summary>
              <div id="AltaeronFaqAnswer-{{ section.id }}-{{ block.id }}" class="altaeron-faq__answer altaeron-rte">{{ block.settings.answer }}</div>
            </details>
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Altaeron keeper's guide",
  "tag": "section",
  "class": "altaeron-template-section",
  "enabled_on": { "templates": ["product"] },
  "blocks": [
    {
      "type": "faq",
      "name": "Global fallback FAQ",
      "settings": [
        { "type": "text", "id": "question", "label": "Question" },
        { "type": "richtext", "id": "answer", "label": "Answer" }
      ]
    }
  ],
  "settings": [
    { "type": "checkbox", "id": "show_section", "label": "Show section", "default": true },
    { "type": "color", "id": "background", "label": "Background", "default": "#050809" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#f4f0e8" },
    { "type": "color", "id": "muted_color", "label": "Muted text", "default": "#9a9b98" },
    { "type": "color", "id": "accent_color", "label": "Accent", "default": "#f3a316" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Keeper's guide" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Everything You Need To Know." },
    { "type": "checkbox", "id": "open_first", "label": "Open first item", "default": true },
    { "type": "checkbox", "id": "one_open", "label": "Only one item open at a time", "default": true }
  ],
  "presets": [{ "name": "Altaeron keeper's guide" }]
}
{% endschema %}
