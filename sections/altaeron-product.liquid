    {"type":"checkbox","id":"show_dynamic_checkout","label":"Show dynamic checkout","default":true},
    {"type":"range","id":"rating","label":"Editorial rating fallback","min":0,"max":5,"step":0.1,"default":0},
    {"type":"number","id":"review_count","label":"Editorial review count fallback","default":0},
    {"type":"url","id":"reviews_link","label":"External reviews link"},
    {"type":"range","id":"low_stock_threshold","label":"Low stock threshold","min":0,"max":50,"step":1,"default":5},
    {"type":"text","id":"social_proof_text","label":"Social proof text"},
    {"type":"text","id":"social_proof_subtext","label":"Social proof supporting text"},
    {"type":"text","id":"dispatch_message","label":"Configured dispatch message"},
    {"type":"text","id":"dispatch_subtext","label":"Dispatch supporting text"},
    {"type":"header","content":"Trust messages"},
    {"type":"text","id":"trust_1_title","label":"Trust item 1 title","default":"Free shipping"},
    {"type":"text","id":"trust_1_text","label":"Trust item 1 text","default":"On qualifying orders."},
    {"type":"text","id":"trust_2_title","label":"Trust item 2 title","default":"30-day returns"},
    {"type":"text","id":"trust_2_text","label":"Trust item 2 text","default":"Easy, no hassle."},
    {"type":"text","id":"trust_3_title","label":"Trust item 3 title","default":"1-year warranty"},
    {"type":"text","id":"trust_3_text","label":"Trust item 3 text","default":"We've got you covered."},
    {"type":"text","id":"trust_4_title","label":"Trust item 4 title","default":"Secure checkout"},
    {"type":"text","id":"trust_4_text","label":"Trust item 4 text","default":"Safe and encrypted."},
    {"type":"header","content":"Before and after"},
    {"type":"image_picker","id":"comparison_before_image","label":"Before image"},
    {"type":"image_picker","id":"comparison_after_image","label":"After image"},
    {"type":"range","id":"comparison_position","label":"Initial divider position","min":10,"max":90,"step":1,"unit":"%","default":50},
    {"type":"text","id":"comparison_before_label","label":"Before label","default":"Without polarization"},
    {"type":"textarea","id":"comparison_before_text","label":"Before text","default":"Glare hides details.\nYou miss what's below."},
    {"type":"text","id":"comparison_before_alt","label":"Before image alt text","default":"Underwater view without polarization"},
    {"type":"text","id":"comparison_after_label","label":"After label","default":"With Altaeron"},
    {"type":"textarea","id":"comparison_after_text","label":"After text","default":"Clarity reveals everything.\nYou see more. You catch more."},
    {"type":"text","id":"comparison_after_alt","label":"After image alt text","default":"Clear underwater view with polarization"},
    {"type":"header","content":"Story sections"},
    {"type":"text","id":"engineering_eyebrow","label":"Engineering eyebrow","default":"Pro-grade lens technology"},
    {"type":"textarea","id":"engineering_heading","label":"Engineering heading","default":"Engineered\nfor anglers"},
    {"type":"textarea","id":"engineering_text","label":"Engineering text","default":"Every detail is designed to help you perform better on the water."},
    {"type":"text","id":"use_cases_heading","label":"Use cases heading","default":"Built for every adventure"},
    {"type":"image_picker","id":"cases_image","label":"Use cases and review image strip"},
    {"type":"text","id":"comparison_heading","label":"Comparison heading","default":"Altaeron vs. the competition"},
    {"type":"text","id":"comparison_brand_1","label":"Comparison brand 1","default":"Altaeron"},
    {"type":"text","id":"comparison_brand_2","label":"Comparison brand 2","default":"Competitor 1"},
    {"type":"text","id":"comparison_brand_3","label":"Comparison brand 3","default":"Competitor 2"},
    {"type":"text","id":"comparison_brand_4","label":"Comparison brand 4","default":"Other glasses"},
    {"type":"text","id":"reviews_heading","label":"Reviews heading","default":"Real reviews from real anglers"},
    {"type":"header","content":"Bundle"},
    {"type":"text","id":"bundle_heading","label":"Bundle heading","default":"Frequently bought together"},
    {"type":"product","id":"bundle_product_1","label":"Bundle accessory 1"},
    {"type":"product","id":"bundle_product_2","label":"Bundle accessory 2"},
    {"type":"product","id":"bundle_product_3","label":"Bundle accessory 3"},
    {"type":"header","content":"FAQ media"},
    {"type":"video","id":"final_video","label":"Hosted video"},
    {"type":"image_picker","id":"final_image","label":"Fallback image"},
    {"type":"text","id":"faq_heading","label":"FAQ heading","default":"FAQ"}
  ],
  "blocks": [
    {"type":"feature","name":"Product feature","settings":[{"type":"select","id":"icon","label":"Icon","default":"sun","options":[{"value":"sun","label":"Sun"},{"value":"shield","label":"Shield"},{"value":"drop","label":"Drop"},{"value":"scratch","label":"Scratch"},{"value":"feather","label":"Feather"}]},{"type":"text","id":"text","label":"Text","default":"Product feature"}]},
    {"type":"benefit","name":"Comparison benefit","settings":[{"type":"text","id":"symbol","label":"Symbol","default":"◉"},{"type":"text","id":"title","label":"Title","default":"Benefit"},{"type":"text","id":"text","label":"Text","default":"Supporting text"}]},
    {"type":"lens_layer","name":"Lens layer","settings":[{"type":"text","id":"title","label":"Title","default":"Lens layer"},{"type":"text","id":"text","label":"Text","default":"Layer description"}]},
    {"type":"use_case","name":"Use case","settings":[{"type":"image_picker","id":"image","label":"Image"},{"type":"text","id":"title","label":"Title","default":"Use case"},{"type":"text","id":"text","label":"Text","default":"Supporting text"}]},
    {"type":"comparison_row","name":"Comparison row","settings":[{"type":"text","id":"feature","label":"Feature","default":"Feature"},{"type":"checkbox","id":"show_product_price","label":"Use current product price for brand 1","default":false},{"type":"text","id":"brand_1","label":"Brand 1 value","default":"✓"},{"type":"text","id":"brand_2","label":"Brand 2 value"},{"type":"text","id":"brand_3","label":"Brand 3 value"},{"type":"text","id":"brand_4","label":"Brand 4 value"}]},
    {"type":"review","name":"Editorial review","settings":[{"type":"image_picker","id":"image","label":"Image"},{"type":"range","id":"rating","label":"Rating","min":1,"max":5,"step":1,"default":5},{"type":"textarea","id":"quote","label":"Quote","default":"Review quote"},{"type":"text","id":"name","label":"Name","default":"Customer name"},{"type":"text","id":"location","label":"Location"},{"type":"checkbox","id":"verified","label":"Verified buyer","default":false}]},
    {"type":"faq","name":"FAQ item","settings":[{"type":"text","id":"question","label":"Question","default":"Question"},{"type":"richtext","id":"answer","label":"Answer","default":"<p>Answer</p>"}]}
  ],
  "presets": [{"name":"Altaeron product page","blocks":[{"type":"feature"},{"type":"benefit"},{"type":"lens_layer"},{"type":"use_case"},{"type":"comparison_row"},{"type":"faq"}]}]
}
{% endschema %}
