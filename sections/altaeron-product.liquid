{% comment %}theme-check-disable RemoteAsset{% endcomment %}
{{ 'section-altaeron-product.css' | asset_url | stylesheet_tag }}
<script src="{{ 'altaeron-product.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign hero_fallback = 'altaeron-product-hero.png' | asset_url
  assign comparison_fallback = 'altaeron-underwater.png' | asset_url
  assign cases_fallback = 'altaeron-use-cases.png' | asset_url
  if section.settings.hero_image != blank
    assign hero_src = section.settings.hero_image | image_url: width: 2000
  elsif current_variant.featured_media != blank
    assign hero_src = current_variant.featured_media.preview_image | image_url: width: 2000
  elsif product.featured_media != blank
    assign hero_src = product.featured_media.preview_image | image_url: width: 2000
  else
    assign hero_src = hero_fallback
  endif
  if section.settings.comparison_before_image != blank
    assign comparison_before_src = section.settings.comparison_before_image | image_url: width: 2200
  else
    assign comparison_before_src = comparison_fallback
  endif
  if section.settings.comparison_after_image != blank
    assign comparison_after_src = section.settings.comparison_after_image | image_url: width: 2200
  else
    assign comparison_after_src = comparison_fallback
  endif
  if section.settings.cases_image != blank
    assign cases_src = section.settings.cases_image | image_url: width: 2200
  else
    assign cases_src = cases_fallback
  endif
  assign display_title = product.title
  assign display_price = current_variant.price | money
  assign rating_value = product.metafields.reviews.rating.value.rating | default: section.settings.rating
  assign review_count = product.metafields.reviews.rating_count.value | default: section.settings.review_count
  assign low_stock = false
  if current_variant.inventory_management == 'shopify' and current_variant.inventory_policy != 'continue' and current_variant.inventory_quantity > 0 and current_variant.inventory_quantity <= section.settings.low_stock_threshold
    assign low_stock = true
  endif
-%}

<svg width="0" height="0" aria-hidden="true" style="position:absolute">
  <symbol id="ap-sun-{{ section.id }}" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3.5" fill="none" stroke="currentColor"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3M4.9 4.9 7 7M17 17l2.1 2.1M19.1 4.9 17 7M7 17l-2.1 2.1" fill="none" stroke="currentColor"/></symbol>
  <symbol id="ap-shield-{{ section.id }}" viewBox="0 0 24 24"><path d="M12 2 20 5v6c0 5.2-3.3 9.1-8 11-4.7-1.9-8-5.8-8-11V5l8-3Z" fill="none" stroke="currentColor"/><path d="m8.5 12 2.2 2.2 4.8-5" fill="none" stroke="currentColor"/></symbol>
  <symbol id="ap-drop-{{ section.id }}" viewBox="0 0 24 24"><path d="M12 2S5.5 9.2 5.5 14.5a6.5 6.5 0 0 0 13 0C18.5 9.2 12 2 12 2Z" fill="none" stroke="currentColor"/><path d="M9 16c.5 1.4 1.6 2.1 3 2.2" fill="none" stroke="currentColor"/></symbol>
  <symbol id="ap-scratch-{{ section.id }}" viewBox="0 0 24 24"><circle cx="12" cy="12" r="9" fill="none" stroke="currentColor"/><path d="m7 16 10-10M10 18l8-8M6 12l6-6" fill="none" stroke="currentColor"/></symbol>
  <symbol id="ap-feather-{{ section.id }}" viewBox="0 0 24 24"><path d="M20 3C11.5 3 5 7.4 5 15.4V21l3.5-5.5C15 15 19.3 10.7 20 3Z" fill="none" stroke="currentColor"/><path d="M5 19c3.2-5.2 6.5-8.6 11-11" fill="none" stroke="currentColor"/></symbol>
  <symbol id="ap-truck-{{ section.id }}" viewBox="0 0 24 24"><path d="M2 5h13v11H2zM15 9h4l3 4v3h-7z" fill="none" stroke="currentColor"/><circle cx="6" cy="18" r="2" fill="none" stroke="currentColor"/><circle cx="18" cy="18" r="2" fill="none" stroke="currentColor"/></symbol>
  <symbol id="ap-return-{{ section.id }}" viewBox="0 0 24 24"><path d="M5 8H1l4-4v4Zm-3 4a10 10 0 1 0 3-7" fill="none" stroke="currentColor"/></symbol>
  <symbol id="ap-lock-{{ section.id }}" viewBox="0 0 24 24"><rect x="4" y="10" width="16" height="11" rx="1" fill="none" stroke="currentColor"/><path d="M8 10V7a4 4 0 0 1 8 0v3M12 14v3" fill="none" stroke="currentColor"/></symbol>
  <symbol id="ap-cart-{{ section.id }}" viewBox="0 0 24 24"><path d="M2 3h3l2 12h11l3-8H6" fill="none" stroke="currentColor"/><circle cx="9" cy="20" r="1.5"/><circle cx="18" cy="20" r="1.5"/></symbol>
</svg>

<article class="ap" data-altaeron-product data-section-id="{{ section.id }}" data-low-stock-threshold="{{ section.settings.low_stock_threshold }}" style="--ap-cases-image:url('{{ cases_src }}')">
  <div class="ap__shell ap__breadcrumb" aria-label="Breadcrumb">
    <a href="{{ routes.root_url }}">Home</a><span>›</span>
    {% if product.collections.first %}<a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a><span>›</span>{% endif %}
    <span>{{ display_title }}</span>
  </div>

  <section class="ap-hero">
    <div class="ap-hero__grid">
      <div class="ap-gallery" data-gallery>
        <div class="ap-gallery__track" data-gallery-track>
          {%- if product.media.size > 0 -%}
            {%- for media in product.media -%}
              {%- liquid
                assign media_loading = 'lazy'
                assign media_priority = 'auto'
                if forloop.first
                  assign media_loading = 'eager'
                  assign media_priority = 'high'
                endif
              -%}
              <figure class="ap-gallery__slide{% if media.id == current_variant.featured_media.id or current_variant.featured_media == blank and forloop.first %} is-active{% endif %}" data-gallery-slide data-media-id="{{ media.id }}" data-media-type="{{ media.media_type }}">
                {%- case media.media_type -%}
                  {%- when 'image' -%}
                    {{ media.preview_image | image_url: width: 2000 | image_tag: loading: media_loading, fetchpriority: media_priority, widths: '390, 600, 900, 1200, 1600, 2000', sizes: '(max-width: 989px) 100vw, 62vw', alt: media.alt | default: display_title }}
                  {%- when 'video', 'external_video' -%}
                    {{ media | media_tag: image_size: '1600x', controls: true, preload: 'metadata' }}
                  {%- when 'model' -%}
                    {{ media | media_tag: image_size: '1600x', toggleable: true }}
                {%- endcase -%}
              </figure>
            {%- endfor -%}
          {%- else -%}
            <figure class="ap-gallery__slide is-active" data-gallery-slide data-media-type="image">
              <img src="{{ hero_src }}" width="1536" height="1024" loading="eager" fetchpriority="high" alt="{{ display_title | escape }}">
            </figure>
          {%- endif -%}
        </div>
        <div class="ap-gallery__shade"></div>
        <div class="ap-gallery__copy">
          <h2 class="ap-gallery__headline">See more.<br>Catch more.<strong>Miss less.</strong></h2>
          <p>Advanced polarization cuts glare so you can see what others miss — and catch more fish.</p>
        </div>
        <div class="ap-gallery__compare" aria-hidden="true"></div>
        <span class="ap-gallery__label ap-gallery__label--before">Without Altaeron</span>
        <span class="ap-gallery__label ap-gallery__label--after">With Altaeron</span>
        <button class="ap-gallery__open" type="button" data-gallery-open aria-haspopup="dialog">◉ <span>View gallery</span></button>
        {%- if product.media.size > 1 -%}
          <div class="ap-gallery__thumbs" data-gallery-thumbs aria-label="Product media thumbnails">
            {%- for media in product.media -%}
              <button class="ap-gallery__thumb{% if media.id == current_variant.featured_media.id or current_variant.featured_media == blank and forloop.first %} is-active{% endif %}" type="button" data-gallery-thumb="{{ forloop.index0 }}" aria-label="View {{ media.media_type }} {{ forloop.index }}">
                {{ media.preview_image | image_url: width: 140 | image_tag: loading: 'lazy', widths: '70, 140', alt: media.alt | default: display_title }}
                {% if media.media_type != 'image' %}<span>{{ media.media_type | replace: 'external_video', 'video' }}</span>{% endif %}
              </button>
            {%- endfor -%}
          </div>
          <button class="ap-gallery__nav ap-gallery__nav--prev" type="button" data-gallery-prev aria-label="Previous media">‹</button>
          <button class="ap-gallery__nav ap-gallery__nav--next" type="button" data-gallery-next aria-label="Next media">›</button>
        {%- endif -%}
        <div class="ap-gallery__dots" data-gallery-dots aria-label="Product media pagination"></div>
        {%- if product.media.size > 1 -%}
          <div class="ap-gallery__chips" aria-label="Quick media navigation">
            {%- for media in product.media -%}<button type="button" data-gallery-chip="{{ forloop.index0 }}">{% if media.media_type == 'image' %}Image {{ forloop.index }}{% else %}{{ media.media_type | replace: 'external_video', 'Video' | capitalize }}{% endif %}</button>{%- endfor -%}
          </div>
        {%- endif -%}
        <div class="ap-proof">
          {% if section.settings.social_proof_text != blank %}<div class="ap-proof__item"><span class="ap-proof__icon">★</span><span class="ap-proof__copy">{{ section.settings.social_proof_text }}<small>{{ section.settings.social_proof_subtext }}</small></span></div>{% endif %}
          <div class="ap-proof__item" data-inventory-proof {% unless low_stock %}hidden{% endunless %}><span class="ap-proof__icon">!</span><span class="ap-proof__copy"><span data-inventory-count>{% if low_stock %}Only {{ current_variant.inventory_quantity }} left{% endif %}</span><small>in stock</small></span></div>
          {% if section.settings.dispatch_message != blank %}<div class="ap-proof__item"><span class="ap-proof__icon">✓</span><span class="ap-proof__copy">{{ section.settings.dispatch_message }}<small>{{ section.settings.dispatch_subtext }}</small></span></div>{% endif %}
        </div>
      </div>

      <div class="ap-buy" id="AltaeronBuyBox-{{ section.id }}">
        <div class="ap-buy__sticky">
          {% if section.settings.badge != blank %}<span class="ap-badge">{{ section.settings.badge }}</span>{% endif %}
          <h1 class="ap-buy__title">{{ display_title }}</h1>
          {% if rating_value > 0 and review_count > 0 %}<button class="ap-rating" type="button" data-scroll-reviews aria-label="Rated {{ rating_value }} out of 5 from {{ review_count }} reviews"><span class="ap-stars" aria-hidden="true">★★★★★</span><span>{{ rating_value }} ({{ review_count }} reviews)</span></button>{% endif %}
          <div class="ap-buy__price" data-product-price>{{ display_price }}</div>
          {% if current_variant.compare_at_price > current_variant.price %}<div class="ap-buy__compare" data-compare-price>{{ current_variant.compare_at_price | money }}</div>{% else %}<div class="ap-buy__compare" data-compare-price hidden></div>{% endif %}
          <div class="ap-inventory" data-inventory-status {% unless low_stock %}hidden{% endunless %}>{% if low_stock %}Only {{ current_variant.inventory_quantity }} left in stock{% endif %}</div>
          {%- assign feature_blocks = section.blocks | where: 'type', 'feature' -%}
          {% if feature_blocks.size > 0 %}
          <div class="ap-feature-grid" aria-label="Product features">
            {% for block in feature_blocks %}<div class="ap-feature" {{ block.shopify_attributes }}><span class="ap-icon"><svg><use href="#ap-{{ block.settings.icon }}-{{ section.id }}"/></svg></span><span>{{ block.settings.text }}</span></div>{% endfor %}
          </div>
          {% endif %}
          {%- unless product.has_only_default_variant -%}
            <div class="ap-variants" data-variant-options>
              {%- for option in product.options_with_values -%}
                {%- assign option_index = forloop.index0 -%}
                <fieldset class="ap-option" data-option-index="{{ option_index }}">
                  <legend class="ap-option__label">{{ option.name }}: <span data-option-label>{{ option.selected_value }}</span></legend>
                  <div class="ap-variant-values">
                    {%- for value in option.values -%}
                      {%- assign input_id = section.id | append: '-option-' | append: option.position | append: '-' | append: forloop.index0 -%}
                      <input class="visually-hidden" type="radio" id="{{ input_id }}" name="options[{{ option.name | escape }}]" value="{{ value | escape }}" data-option-input data-option-index="{{ option_index }}" {% if value.selected %}checked{% endif %} {% unless value.available %}data-unavailable{% endunless %}>
                      <label class="ap-variant-value{% if value.swatch %} ap-variant-value--swatch{% endif %}" for="{{ input_id }}" {% if value.swatch.color %}style="--variant-swatch:rgb({{ value.swatch.color.rgb }})"{% elsif value.swatch.image %}style="--variant-swatch:url('{{ value.swatch.image | image_url: width: 80 }}')"{% endif %}><span>{{ value }}</span></label>
                    {%- endfor -%}
                  </div>
                </fieldset>
              {%- endfor -%}
            </div>
          {%- endunless -%}
          {%- assign product_form_id = 'AltaeronProductForm-' | append: section.id -%}
          {% form 'product', product, id: product_form_id, class: 'ap-product-form', is: 'product-form', data-hide-errors: false, data-product-id: product.id %}
            <input type="hidden" name="id" value="{{ current_variant.id }}" class="product-variant-id" data-variant-id>
            <div class="ap-purchase-row">
              <div class="ap-qty" data-quantity>
                <button type="button" data-qty-minus aria-label="Decrease quantity">−</button>
                <input name="quantity" value="{{ current_variant.quantity_rule.min }}" min="{{ current_variant.quantity_rule.min }}" step="{{ current_variant.quantity_rule.increment }}" {% if current_variant.quantity_rule.max %}max="{{ current_variant.quantity_rule.max }}"{% endif %} inputmode="numeric" aria-label="Quantity" data-quantity-input>
                <button type="button" data-qty-plus aria-label="Increase quantity">+</button>
              </div>
              <button class="ap-btn ap-btn--primary" type="submit" name="add" {% unless current_variant.available %}disabled aria-disabled="true"{% endunless %}><svg width="18" height="18"><use href="#ap-cart-{{ section.id }}"/></svg><span data-add-label>{% if current_variant.available %}Add to cart{% else %}Sold out{% endif %}</span></button>
            </div>
            {% if section.settings.show_dynamic_checkout and product.selling_plan_groups == empty %}<div class="ap-dynamic-checkout">{{ form | payment_button }}</div>{% endif %}
            <div class="ap-installments">{{ form | payment_terms }}</div>
            <div class="product-form__error-message ap-form-error" role="alert" hidden></div>
          {% endform %}
          <div class="ap-payment" aria-label="Accepted payment methods">{% for type in shop.enabled_payment_types %}<span>{{ type | payment_type_svg_tag }}</span>{% endfor %}</div>
          <p class="visually-hidden" role="status" aria-live="polite" data-cart-status></p>
        </div>
      </div>
    </div>
  </section>

  <section class="ap-trust-strip">
    <div class="ap__shell ap-trust-grid">
      {% if section.settings.trust_1_title != blank %}<div class="ap-trust"><span class="ap-icon"><svg><use href="#ap-truck-{{ section.id }}"/></svg></span><span><strong>{{ section.settings.trust_1_title }}</strong><small>{{ section.settings.trust_1_text }}</small></span></div>{% endif %}
      {% if section.settings.trust_2_title != blank %}<div class="ap-trust"><span class="ap-icon"><svg><use href="#ap-return-{{ section.id }}"/></svg></span><span><strong>{{ section.settings.trust_2_title }}</strong><small>{{ section.settings.trust_2_text }}</small></span></div>{% endif %}
      {% if section.settings.trust_3_title != blank %}<div class="ap-trust"><span class="ap-icon"><svg><use href="#ap-shield-{{ section.id }}"/></svg></span><span><strong>{{ section.settings.trust_3_title }}</strong><small>{{ section.settings.trust_3_text }}</small></span></div>{% endif %}
      {% if section.settings.trust_4_title != blank %}<div class="ap-trust"><span class="ap-icon"><svg><use href="#ap-lock-{{ section.id }}"/></svg></span><span><strong>{{ section.settings.trust_4_title }}</strong><small>{{ section.settings.trust_4_text }}</small></span></div>{% endif %}
    </div>
  </section>

  <div class="ap__shell">
    <section class="ap-section" id="SeeTheDifference">
      <div class="ap-section__head"><h2 class="ap__section-title" style="color:var(--ap-orange)">See the difference</h2></div>
      <div class="ap-comparison ap__card" data-comparison style="--comparison-position:{{ section.settings.comparison_position }}%">
        <div class="ap-comparison__image"><img src="{{ comparison_before_src }}" width="2048" height="800" loading="lazy" alt="{{ section.settings.comparison_before_alt | escape }}"></div>
        <div class="ap-comparison__clear" data-comparison-clear><img src="{{ comparison_after_src }}" width="2048" height="800" loading="lazy" alt="{{ section.settings.comparison_after_alt | escape }}"></div>
        <div class="ap-comparison__caption ap-comparison__caption--left"><strong>{{ section.settings.comparison_before_label }}</strong><span>{{ section.settings.comparison_before_text | newline_to_br }}</span></div>
        <div class="ap-comparison__caption ap-comparison__caption--right"><strong>{{ section.settings.comparison_after_label }}</strong><span>{{ section.settings.comparison_after_text | newline_to_br }}</span></div>
        <div class="ap-comparison__divider" data-comparison-divider><span class="ap-comparison__handle">↔</span></div>
        <input type="range" min="8" max="92" value="{{ section.settings.comparison_position }}" aria-label="Compare polarized and non-polarized view" data-comparison-range>
      </div>
      {%- assign benefit_blocks = section.blocks | where: 'type', 'benefit' -%}{% if benefit_blocks.size > 0 %}<div class="ap-benefits">{% for block in benefit_blocks %}<div class="ap-benefit" {{ block.shopify_attributes }}><span class="ap-icon">{{ block.settings.symbol }}</span><span><strong>{{ block.settings.title }}</strong><span>{{ block.settings.text }}</span></span></div>{% endfor %}</div>{% endif %}
    </section>

    <section class="ap-section ap-collapse" data-mobile-collapse>
      <button class="ap-mobile-toggle" type="button" aria-expanded="false" aria-controls="AltaeronEngineering-{{ section.id }}">{{ section.settings.engineering_eyebrow }}</button>
      <div class="ap-section__head"><div><p class="ap__eyebrow">{{ section.settings.engineering_eyebrow }}</p><h2 class="ap__section-title">{{ section.settings.engineering_heading | newline_to_br }}</h2></div></div>
      <div class="ap-collapse__content ap-engineering" id="AltaeronEngineering-{{ section.id }}">
        <div class="ap-engineering__intro"><p>{{ section.settings.engineering_text }}</p></div>
        {%- assign layer_blocks = section.blocks | where: 'type', 'lens_layer' -%}<div class="ap-lenses" aria-label="Exploded view of {{ layer_blocks.size }} lens layers">{% for block in layer_blocks %}<span class="ap-lens"></span>{% endfor %}</div>
        <ol class="ap-engineering__layers">{% for block in layer_blocks %}<li {{ block.shopify_attributes }}><span><strong>{{ block.settings.title }}</strong>{{ block.settings.text }}</span></li>{% endfor %}</ol>
      </div>
    </section>

    <section class="ap-section ap-collapse" data-mobile-collapse>
      <button class="ap-mobile-toggle" type="button" aria-expanded="false" aria-controls="AltaeronCases-{{ section.id }}">{{ section.settings.use_cases_heading }}</button>
      <div class="ap-section__head"><h2 class="ap__section-title">{{ section.settings.use_cases_heading }}</h2></div>
      <div class="ap-collapse__content ap-cases" id="AltaeronCases-{{ section.id }}">
        {% assign use_case_blocks = section.blocks | where: 'type', 'use_case' %}{% for block in use_case_blocks %}<article class="ap-case" {{ block.shopify_attributes }}>{% if block.settings.image %}{{ block.settings.image | image_url: width: 600 | image_tag: class: 'ap-case__image', loading: 'lazy', widths: '240, 400, 600', sizes: '(max-width: 989px) 72vw, 20vw' }}{% else %}<div class="ap-case__image" style="background-image:url('{{ cases_src }}');--position:{{ forloop.index0 | times: 25 }}% center"><span aria-hidden="true"></span></div>{% endif %}<div class="ap-case__copy"><strong>{{ block.settings.title }}</strong><span>{{ block.settings.text }}</span></div></article>{% endfor %}
      </div>
    </section>

    <section class="ap-section ap-collapse" data-mobile-collapse>
      <button class="ap-mobile-toggle" type="button" aria-expanded="false" aria-controls="AltaeronTable-{{ section.id }}">{{ section.settings.comparison_heading }}</button>
      <div class="ap-section__head"><h2 class="ap__section-title">{{ section.settings.comparison_heading }}</h2></div>
      <div class="ap-collapse__content ap-table-scroll" id="AltaeronTable-{{ section.id }}"><table class="ap-table"><thead><tr class="ap-table__row ap-table__head"><th scope="col">Features</th><th scope="col">{{ section.settings.comparison_brand_1 }}</th><th scope="col">{{ section.settings.comparison_brand_2 }}</th><th scope="col">{{ section.settings.comparison_brand_3 }}</th><th scope="col">{{ section.settings.comparison_brand_4 }}</th></tr></thead><tbody class="ap-table__body">{% assign table_blocks = section.blocks | where: 'type', 'comparison_row' %}{% for block in table_blocks %}<tr class="ap-table__row" {{ block.shopify_attributes }}><th scope="row">{{ block.settings.feature }}</th><td>{% if block.settings.show_product_price %}{{ display_price }}{% else %}{{ block.settings.brand_1 }}{% endif %}</td><td>{{ block.settings.brand_2 }}</td><td>{{ block.settings.brand_3 }}</td><td>{{ block.settings.brand_4 }}</td></tr>{% endfor %}</tbody></table></div>
    </section>

    {% assign review_blocks = section.blocks | where: 'type', 'review' %}{% if review_blocks.size > 0 %}<section class="ap-section ap-collapse is-open" data-mobile-collapse id="AltaeronReviews">
      <button class="ap-mobile-toggle" type="button" aria-expanded="true" aria-controls="AltaeronReviewGrid-{{ section.id }}">{{ section.settings.reviews_heading }}{% if section.settings.reviews_link != blank %} <span>View all →</span>{% endif %}</button>
      <div class="ap-section__head"><h2 class="ap__section-title">{{ section.settings.reviews_heading }}</h2>{% if section.settings.reviews_link != blank %}<a class="ap-section__link" href="{{ section.settings.reviews_link }}">View all reviews →</a>{% endif %}</div>
      <div class="ap-collapse__content ap-review-grid" id="AltaeronReviewGrid-{{ section.id }}">{% for block in review_blocks %}<article class="ap-review ap__card" {{ block.shopify_attributes }}>{% if block.settings.image %}{{ block.settings.image | image_url: width: 480 | image_tag: class: 'ap-review__image', loading: 'lazy', widths: '160, 320, 480', sizes: '100px' }}{% else %}<div class="ap-review__image" style="background-image:url('{{ cases_src }}');--position:{{ forloop.index0 | times: 25 }}% center"><span aria-hidden="true"></span></div>{% endif %}<div class="ap-review__body"><span class="ap-stars" aria-label="{{ block.settings.rating }} out of 5 stars">{% for star in (1..block.settings.rating) %}★{% endfor %}</span><p>“{{ block.settings.quote }}”</p><strong>{{ block.settings.name }}</strong><small>{{ block.settings.location }}</small>{% if block.settings.verified %}<small class="ap-verified">◉ Verified Buyer</small>{% endif %}</div></article>{% endfor %}</div>
    </section>{% endif %}

    {%- assign bundle_1 = section.settings.bundle_product_1 -%}
    {%- assign bundle_2 = section.settings.bundle_product_2 -%}
    {%- assign bundle_3 = section.settings.bundle_product_3 -%}
    {% if bundle_1 != blank or bundle_2 != blank or bundle_3 != blank %}
      <section class="ap-section">
        <div class="ap__card"><div class="ap-section__head" style="padding:14px 14px 0"><h2 class="ap__section-title">{{ section.settings.bundle_heading }}</h2></div>
          <div class="ap-bundle">
            <div class="ap-bundle__item"><input type="checkbox" checked disabled aria-label="{{ display_title | escape }} is required"><img class="ap-bundle__visual" src="{{ hero_src }}" width="320" height="184" loading="lazy" alt="{{ display_title | escape }}"><strong>{{ display_title }}</strong><small data-bundle-base-price>{{ display_price }}</small></div>
            {% for accessory in (1..3) %}
              {% case accessory %}{% when 1 %}{% assign bundle_product = bundle_1 %}{% when 2 %}{% assign bundle_product = bundle_2 %}{% when 3 %}{% assign bundle_product = bundle_3 %}{% endcase %}
              {% if bundle_product != blank %}{% assign bundle_variant = bundle_product.selected_or_first_available_variant %}<label class="ap-bundle__item"><input type="checkbox" value="{{ bundle_variant.id }}" data-bundle-item data-price="{{ bundle_variant.price }}" data-compare-at-price="{{ bundle_variant.compare_at_price | default: bundle_variant.price }}" {% if bundle_variant.available %}checked{% else %}disabled{% endif %}>{% if bundle_product.featured_image %}{{ bundle_product.featured_image | image_url: width: 320 | image_tag: class: 'ap-bundle__visual', loading: 'lazy', widths: '160, 320', sizes: '(max-width: 989px) 80px, 220px' }}{% endif %}<strong>{{ bundle_product.title }}</strong><small>{{ bundle_variant.price | money }}{% unless bundle_variant.available %} · Sold out{% endunless %}</small></label>{% endif %}
            {% endfor %}
            <div class="ap-bundle__total"><small>Total price</small><div class="ap-bundle__price"><span data-bundle-price>{{ display_price }}</span> <small class="ap-bundle__compare" data-bundle-compare hidden></small></div><div class="ap-bundle__save" data-bundle-save hidden></div><button class="ap-btn ap-btn--primary" type="button" data-add-bundle><svg width="18" height="18"><use href="#ap-cart-{{ section.id }}"/></svg><span>Add bundle to cart</span></button></div>
          </div>
        </div>
      </section>
    {% endif %}

    <section class="ap-trust-strip">
      <div class="ap-trust-grid">
        {% if section.settings.trust_1_title != blank %}<div class="ap-trust"><span class="ap-icon"><svg><use href="#ap-truck-{{ section.id }}"/></svg></span><span><strong>{{ section.settings.trust_1_title }}</strong><small>{{ section.settings.trust_1_text }}</small></span></div>{% endif %}
        {% if section.settings.trust_2_title != blank %}<div class="ap-trust"><span class="ap-icon"><svg><use href="#ap-return-{{ section.id }}"/></svg></span><span><strong>{{ section.settings.trust_2_title }}</strong><small>{{ section.settings.trust_2_text }}</small></span></div>{% endif %}
        {% if section.settings.trust_3_title != blank %}<div class="ap-trust"><span class="ap-icon"><svg><use href="#ap-shield-{{ section.id }}"/></svg></span><span><strong>{{ section.settings.trust_3_title }}</strong><small>{{ section.settings.trust_3_text }}</small></span></div>{% endif %}
        {% if section.settings.trust_4_title != blank %}<div class="ap-trust"><span class="ap-icon"><svg><use href="#ap-lock-{{ section.id }}"/></svg></span><span><strong>{{ section.settings.trust_4_title }}</strong><small>{{ section.settings.trust_4_text }}</small></span></div>{% endif %}
      </div>
    </section>

    {% assign faq_blocks = section.blocks | where: 'type', 'faq' %}{% if faq_blocks.size > 0 %}<section class="ap-section ap-final">
      <div class="ap-final__video ap__card">{% if section.settings.final_video %}{{ section.settings.final_video | video_tag: controls: true, preload: 'metadata', image_size: '1200x' }}{% elsif section.settings.final_image %}{{ section.settings.final_image | image_url: width: 1200 | image_tag: loading: 'lazy', widths: '390, 720, 960, 1200', sizes: '(max-width: 989px) 100vw, 38vw', alt: section.settings.final_image.alt }}{% else %}<img src="{{ cases_src }}" loading="lazy" width="2048" height="683" alt="">{% endif %}</div>
      <div><div class="ap-section__head"><h2 class="ap__section-title">{{ section.settings.faq_heading }}</h2></div><div class="ap-faq">{% for block in faq_blocks %}<details {{ block.shopify_attributes }}><summary>{{ block.settings.question }}</summary><div class="rte">{{ block.settings.answer }}</div></details>{% endfor %}</div></div>
    </section>{% endif %}
  </div>

  <div class="ap-sticky" data-sticky-atc>
    <img src="{{ hero_src }}" width="48" height="48" alt="">
    <div><div class="ap-sticky__price"><span data-sticky-price>{{ display_price }}</span> <s class="ap-sticky__compare" data-sticky-compare {% unless current_variant.compare_at_price > current_variant.price %}hidden{% endunless %}>{% if current_variant.compare_at_price > current_variant.price %}{{ current_variant.compare_at_price | money }}{% endif %}</s></div><div class="ap-sticky__variant" data-sticky-variant>{% unless current_variant.title == 'Default Title' %}{{ current_variant.title }}{% endunless %}</div></div>
    <button class="ap-btn ap-btn--primary" type="button" data-sticky-submit {% unless current_variant.available %}disabled{% endunless %}><svg width="16" height="16"><use href="#ap-cart-{{ section.id }}"/></svg><span>{% if current_variant.available %}Add to cart{% else %}Sold out{% endif %}</span></button>
  </div>

  <dialog class="ap-modal" data-gallery-modal aria-label="Product media gallery">
    <button class="ap-modal__close" type="button" data-gallery-close aria-label="Close gallery">×</button>
    <div class="ap-modal__inner">
      <div class="ap-modal__thumbs" data-modal-thumbs>
        {% if product.media.size > 0 %}{% for media in product.media %}<button class="ap-modal__thumb{% if media.id == current_variant.featured_media.id or current_variant.featured_media == blank and forloop.first %} is-active{% endif %}" type="button" data-modal-thumb="{{ forloop.index0 }}">{{ media.preview_image | image_url: width: 180 | image_tag: loading: 'lazy', widths: '90, 180', alt: media.alt | default: display_title }}</button>{% endfor %}{% else %}<button class="ap-modal__thumb is-active" type="button" data-modal-thumb="0"><img src="{{ hero_src }}" width="180" height="120" alt="{{ display_title | escape }}"></button>{% endif %}
      </div>
      <div class="ap-modal__stage" data-modal-stage>
        {% if product.media.size > 0 %}{% for media in product.media %}<div data-modal-media {% unless media.id == current_variant.featured_media.id or current_variant.featured_media == blank and forloop.first %}hidden{% endunless %}>{% if media.media_type == 'image' %}{{ media.preview_image | image_url: width: 2000 | image_tag: loading: 'lazy', widths: '720, 1200, 1600, 2000', sizes: '90vw', alt: media.alt | default: display_title }}{% else %}{{ media | media_tag: image_size: '1800x', controls: true }}{% endif %}</div>{% endfor %}{% else %}<div data-modal-media><img src="{{ hero_src }}" width="1536" height="1024" alt="{{ display_title | escape }}"></div>{% endif %}
        <button class="ap-modal__nav ap-modal__nav--prev" type="button" data-modal-prev aria-label="Previous media">‹</button><button class="ap-modal__nav ap-modal__nav--next" type="button" data-modal-next aria-label="Next media">›</button>
      </div>
    </div>
  </dialog>
  <script type="application/json" data-variant-json>[{% for variant in product.variants %}{"id":{{ variant.id | json }},"title":{{ variant.title | json }},"options":{{ variant.options | json }},"available":{{ variant.available | json }},"price":{{ variant.price | json }},"price_formatted":{{ variant.price | money | json }},"compare_at_price":{{ variant.compare_at_price | default: 0 | json }},"compare_at_price_formatted":{{ variant.compare_at_price | money | json }},"featured_media_id":{% if variant.featured_media %}{{ variant.featured_media.id | json }}{% else %}null{% endif %},"inventory_management":{{ variant.inventory_management | json }},"inventory_policy":{{ variant.inventory_policy | json }},"inventory_quantity":{{ variant.inventory_quantity | json }},"quantity_rule":{"min":{{ variant.quantity_rule.min | json }},"max":{{ variant.quantity_rule.max | json }},"increment":{{ variant.quantity_rule.increment | json }}}}{% unless forloop.last %},{% endunless %}{% endfor %}]</script>
</article>

{% schema %}
{
  "name": "Altaeron product page",
  "tag": "section",
  "class": "altaeron-product-section",
  "max_blocks": 50,
  "settings": [
    {"type":"header","content":"Product purchase"},
    {"type":"text","id":"badge","label":"Badge","default":"Best seller"},
