{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'section-altaeron-footer.css' | asset_url | stylesheet_tag }}
<script src="{{ 'footer.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign socials = 'facebook,instagram,youtube,tiktok,pinterest'
  assign socials_arr = socials | split: ','
  assign has_social_icons = false
  for social in socials_arr
    assign setting_key = 'social_' | append: social | append: '_link'
    if settings[setting_key] != blank
      assign has_social_icons = true
      break
    endif
  endfor

  assign shop_menu = section.settings.shop_menu
  assign support_menu = section.settings.support_menu
  assign company_menu = section.settings.company_menu

  if section.settings.story_image != blank
    assign story_image_url = section.settings.story_image | image_url: width: 1200
  else
    assign story_image_url = 'altaeron-alpine.webp' | asset_url
  endif
-%}

<footer
  id="SiteFooter"
  class="altaeron-site-footer"
  aria-label="Footer"
  style="--altaeron-footer-story-image: url('{{ story_image_url }}');"
>
  <div class="altaeron-site-footer__grid">
    <div class="altaeron-site-footer__brand">
      <a class="altaeron-site-footer__brand-link" href="{{ routes.root_url }}" aria-label="{{ shop.name | escape }} - Home">
        {% render 'altaeron-brand', text: shop.name, class: 'altaeron-brand--footer' %}
      </a>

      <p>{{ section.settings.brand_text }}</p>

      {%- if section.settings.show_social and has_social_icons -%}
        {%- render 'social-icons', class: 'altaeron-site-footer__socials', size: 'small' -%}
      {%- endif -%}
    </div>

    <details is="footer-details" class="altaeron-site-footer__menu" open data-open-default="false">
      <summary>
        <span>Shop</span>
        <span class="altaeron-site-footer__toggle" aria-hidden="true">+</span>
      </summary>
      <ul class="list-unstyled">
        {%- if shop_menu != blank and shop_menu.links.size > 0 -%}
          {%- for link in shop_menu.links -%}
            <li><a href="{{ link.url }}">{{ link.title | escape }}</a></li>
          {%- endfor -%}
        {%- else -%}
          <li><a href="{{ routes.all_products_collection_url }}">All Products</a></li>
          <li><a href="{{ routes.root_url }}collections/best-sellers">Best Sellers</a></li>
          <li><a href="{{ routes.root_url }}collections/new-arrivals">New Arrivals</a></li>
          <li><a href="{{ routes.root_url }}pages/custom-lamps">Custom Lamps</a></li>
          <li><a href="{{ routes.root_url }}products/gift-card">Gift Cards</a></li>
        {%- endif -%}
      </ul>
    </details>

    <details is="footer-details" class="altaeron-site-footer__menu" open data-open-default="false">
      <summary>
        <span>Help &amp; Support</span>
        <span class="altaeron-site-footer__toggle" aria-hidden="true">+</span>
      </summary>
      <ul class="list-unstyled">
        {%- if support_menu != blank and support_menu.links.size > 0 -%}
          {%- for link in support_menu.links -%}
            <li><a href="{{ link.url }}">{{ link.title | escape }}</a></li>
          {%- endfor -%}
        {%- else -%}
          <li><a href="{{ routes.root_url }}pages/faq">FAQ</a></li>
          <li><a href="{{ routes.root_url }}policies/shipping-policy">Shipping &amp; Delivery</a></li>
          <li><a href="{{ routes.root_url }}policies/refund-policy">Returns &amp; Refunds</a></li>
          <li><a href="{{ routes.root_url }}pages/track-order">Track Order</a></li>
          <li><a href="{{ routes.root_url }}pages/contact">Contact Us</a></li>
        {%- endif -%}
      </ul>
    </details>

    <details is="footer-details" class="altaeron-site-footer__menu" open data-open-default="false">
      <summary>
        <span>Company</span>
        <span class="altaeron-site-footer__toggle" aria-hidden="true">+</span>
      </summary>
      <ul class="list-unstyled">
        {%- if company_menu != blank and company_menu.links.size > 0 -%}
          {%- for link in company_menu.links -%}
            <li><a href="{{ link.url }}">{{ link.title | escape }}</a></li>
          {%- endfor -%}
        {%- else -%}
          <li><a href="{{ routes.root_url }}pages/about">Our Story</a></li>
          <li><a href="{{ routes.root_url }}pages/materials">Materials</a></li>
          <li><a href="{{ routes.root_url }}pages/care-guide">Care Guide</a></li>
          <li><a href="{{ routes.root_url }}pages/sustainability">Sustainability</a></li>
          <li><a href="{{ routes.root_url }}pages/reviews">Reviews</a></li>
        {%- endif -%}
      </ul>
    </details>

    <div class="altaeron-site-footer__story">
      <div class="altaeron-site-footer__story-copy">
        <span class="altaeron-site-footer__quote" aria-hidden="true">&ldquo;</span>
        <h2>{{ section.settings.story_heading | newline_to_br }}</h2>
        <p>{{ section.settings.story_text | newline_to_br }}</p>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Altaeron footer",
  "enabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "textarea",
      "id": "brand_text",
      "label": "Brand description",
      "default": "We preserve worlds in resin, handcrafted lamps that blend nature, fantasy, and light into timeless masterpieces."
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show social icons",
      "default": true
    },
    {
      "type": "link_list",
      "id": "shop_menu",
      "label": "Shop menu"
    },
    {
      "type": "link_list",
      "id": "support_menu",
      "label": "Help & Support menu"
    },
    {
      "type": "link_list",
      "id": "company_menu",
      "label": "Company menu"
    },
    {
      "type": "header",
      "content": "Story panel"
    },
    {
      "type": "image_picker",
      "id": "story_image",
      "label": "Background image"
    },
    {
      "type": "textarea",
      "id": "story_heading",
      "label": "Heading",
      "default": "Every Light\nHolds A Story."
    },
    {
      "type": "textarea",
      "id": "story_text",
      "label": "Text",
      "default": "Thank you for being\npart of ours."
    }
  ],
  "presets": [
    {
      "name": "Altaeron footer"
    }
  ]
}
{% endschema %}
