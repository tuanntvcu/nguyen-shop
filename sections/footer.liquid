{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'section-altaeron-footer.css' | asset_url | stylesheet_tag }}
<script src="{{ 'footer.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign socials = 'facebook,instagram,youtube,tiktok,pinterest'
  assign socials_arr = socials | split: ','
  assign has_social_icons = false
  for social in socials_arr
    assign setting_key = 'social_' | append: social | append: '_link'
    if settings[setting_key] != blank
      assign has_social_icons = true
      break
    endif
  endfor

  assign shop_menu = section.settings.shop_menu
  assign support_menu = section.settings.support_menu
  assign company_menu = section.settings.company_menu
  assign footer_logo = settings.logo
  assign footer_logo_mobile = settings.logo_mobile
  assign footer_logo_width = settings.logo_width
  assign footer_logo_width_2x = footer_logo_width | times: 2
  assign footer_logo_mobile_width = settings.logo_width_mobile
  assign footer_logo_mobile_width_2x = footer_logo_mobile_width | times: 2

  if footer_logo_mobile == blank
    assign footer_logo_mobile = footer_logo
  endif

  if footer_logo == blank
    assign footer_logo = footer_logo_mobile
  endif

  if section.settings.story_image != blank
    assign story_image_url = section.settings.story_image | image_url: width: 1200
  else
    assign story_image_url = 'altaeron-alpine.webp' | asset_url
  endif
-%}

<footer
  id="SiteFooter"
  class="altaeron-site-footer"
  aria-label="Footer"
  style="--altaeron-footer-story-image: url('{{ story_image_url }}');"
>
  <div class="altaeron-site-footer__grid">
    <div class="altaeron-site-footer__brand">
      <a
        class="altaeron-site-footer__brand-link"
        href="{{ routes.root_url }}"
        aria-label="{{ shop.name | escape }} - Home"
        style="--altaeron-footer-logo-width: {{ footer_logo_width }}px; --altaeron-footer-logo-width-mobile: {{ footer_logo_mobile_width }}px;"
      >
        {%- if footer_logo != blank -%}
          <picture>
            {%- if footer_logo_mobile != blank -%}
              <source
                media="(max-width: 767.98px)"
                srcset="{{ footer_logo_mobile | image_url: width: footer_logo_mobile_width }} 1x, {{ footer_logo_mobile | image_url: width: footer_logo_mobile_width_2x }} 2x"
              >
            {%- endif -%}
            <img
              class="altaeron-site-footer__logo"
              srcset="{{ footer_logo | image_url: width: footer_logo_width }} 1x, {{ footer_logo | image_url: width: footer_logo_width_2x }} 2x"
              src="{{ footer_logo | image_url: width: footer_logo_width }}"
              width="{{ footer_logo_width }}"
              height="{{ footer_logo_width | divided_by: footer_logo.aspect_ratio | round }}"
              loading="lazy"
              alt="{{ footer_logo.alt | default: shop.name | escape }}"
            >
          </picture>
        {%- else -%}
          {% render 'altaeron-brand', text: shop.name, class: 'altaeron-brand--footer' %}
        {%- endif -%}
      </a>

      <p>{{ section.settings.brand_text }}</p>

      {%- if section.settings.show_social and has_social_icons -%}
        {%- render 'social-icons', class: 'altaeron-site-footer__socials', size: 'small' -%}
      {%- endif -%}
    </div>

    <details is="footer-details" class="altaeron-site-footer__menu" open data-open-default="false">
      <summary>
        <span>{{ shop_menu.title | default: 'Shop' | escape }}</span>
        <span class="altaeron-site-footer__toggle" aria-hidden="true">+</span>
      </summary>
      <ul class="list-unstyled">
        {%- for link in shop_menu.links -%}
          <li><a href="{{ link.url }}">{{ link.title | escape }}</a></li>
        {%- endfor -%}
      </ul>
    </details>

    <details is="footer-details" class="altaeron-site-footer__menu" open data-open-default="false">
      <summary>
        <span>{{ support_menu.title | default: 'Help & Support' | escape }}</span>
        <span class="altaeron-site-footer__toggle" aria-hidden="true">+</span>
      </summary>
      <ul class="list-unstyled">
        {%- for link in support_menu.links -%}
          <li><a href="{{ link.url }}">{{ link.title | escape }}</a></li>
        {%- endfor -%}
      </ul>
    </details>

    <details is="footer-details" class="altaeron-site-footer__menu" open data-open-default="false">
      <summary>
        <span>{{ company_menu.title | default: 'Company' | escape }}</span>
        <span class="altaeron-site-footer__toggle" aria-hidden="true">+</span>
      </summary>
      <ul class="list-unstyled">
        {%- for link in company_menu.links -%}
          <li><a href="{{ link.url }}">{{ link.title | escape }}</a></li>
        {%- endfor -%}
      </ul>
    </details>

    <div class="altaeron-site-footer__story">
      <div class="altaeron-site-footer__story-copy">
        <span class="altaeron-site-footer__quote" aria-hidden="true">&ldquo;</span>
        <h2>{{ section.settings.story_heading | newline_to_br }}</h2>
        <p>{{ section.settings.story_text | newline_to_br }}</p>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Altaeron footer",
  "enabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "textarea",
      "id": "brand_text",
      "label": "Brand description",
      "default": "We preserve worlds in resin, handcrafted lamps that blend nature, fantasy, and light into timeless masterpieces."
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show social icons",
      "default": true
    },
    {
      "type": "link_list",
      "id": "shop_menu",
      "label": "Shop menu"
    },
    {
      "type": "link_list",
      "id": "support_menu",
      "label": "Help & Support menu"
    },
    {
      "type": "link_list",
      "id": "company_menu",
      "label": "Company menu"
    },
    {
      "type": "header",
      "content": "Story panel"
    },
    {
      "type": "image_picker",
      "id": "story_image",
      "label": "Background image"
    },
    {
      "type": "textarea",
      "id": "story_heading",
      "label": "Heading",
      "default": "Every Light\nHolds A Story."
    },
    {
      "type": "textarea",
      "id": "story_text",
      "label": "Text",
      "default": "Thank you for being\npart of ours."
    }
  ],
  "presets": [
    {
      "name": "Altaeron footer"
    }
  ]
}
{% endschema %}
