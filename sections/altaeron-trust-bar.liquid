{{ 'section-altaeron-home.css' | asset_url | stylesheet_tag }}

<section class="altaeron-section altaeron-trust altaeron-trust--{{ section.settings.visibility }}" data-section-id="{{ section.id }}">
  <div class="page-width">
    {%- if section.settings.mobile_heading != blank -%}
      <div class="altaeron-trust__mobile-heading">{{ section.settings.mobile_heading }}</div>
    {%- endif -%}
    <div class="altaeron-trust__grid">
      {%- for block in section.blocks -%}
        <div class="altaeron-trust__item" {{ block.shopify_attributes }}>
          <span class="altaeron-icon">
            {%- if block.settings.icon != blank -%}
              {{
                block.settings.icon
                | image_url: width: 96
                | image_tag:
                  loading: 'lazy',
                  widths: '48, 72, 96',
                  class: 'altaeron-icon__image',
                  alt: block.settings.title
              }}
            {%- else -%}
              {%- render 'icon-check' -%}
            {%- endif -%}
          </span>
          <div>
            <p class="altaeron-trust__title">{{ block.settings.title }}</p>
            <p class="altaeron-trust__text">{{ block.settings.text }}</p>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Altaeron trust bar",
  "tag": "section",
  "class": "section",
  "max_blocks": 5,
  "disabled_on": {
    "groups": ["header", "footer", "custom.overlay"]
  },
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "FREE SHIPPING"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "On orders over $79."
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "select",
      "id": "visibility",
      "label": "Visibility",
      "default": "all",
      "options": [
        {
          "value": "all",
          "label": "Desktop and mobile"
        },
        {
          "value": "mobile",
          "label": "Mobile only"
        }
      ]
    },
    {
      "type": "text",
      "id": "mobile_heading",
      "label": "Mobile heading",
      "default": "TRUSTED BY 50,000+ ANGLERS"
    }
  ],
  "presets": [
    {
      "name": "Altaeron trust bar",
      "blocks": [
        {
          "type": "benefit"
        },
        {
          "type": "benefit"
        },
        {
          "type": "benefit"
        },
        {
          "type": "benefit"
        },
        {
          "type": "benefit"
        }
      ]
    }
  ]
}
{% endschema %}
