{%- liquid
  assign packaging_image = product.metafields.custom.packaging_image.value
  assign packaging_heading = product.metafields.custom.packaging_heading.value
  assign packaging_content = product.metafields.custom.packaging_content
  assign lifestyle_gallery = product.metafields.custom.lifestyle_gallery.value
  assign featured_review = product.metafields.custom.featured_review_v2.value | default: product.metafields.custom.featured_review.value | default: product.metafields.custom.story_card.value
  assign rating = product.metafields.reviews.rating.value
  assign rating_count = product.metafields.reviews.rating_count.value
  assign show_editorial_story = section.settings.show_editorial_story
  assign show_judgeme_widget = section.settings.show_judgeme_widget
  assign has_packaging = false
  if packaging_image != blank or packaging_heading != blank or packaging_content != blank
    assign has_packaging = true
  endif
  assign has_stories = false
  if rating != blank or section.blocks.size > 0 or show_judgeme_widget or request.design_mode
    assign has_stories = true
  elsif show_editorial_story and featured_review != blank
    assign has_stories = true
  endif
  assign stories_eyebrow = section.settings.stories_eyebrow
  assign stories_heading = section.settings.stories_heading
  assign stories_mobile_heading = section.settings.stories_mobile_heading
-%}

{{ 'altaeron-product.css' | asset_url | stylesheet_tag }}

<div class="altaeron-aftercare altaeron-surface" style="--altaeron-bg: {{ section.settings.background }}; --altaeron-text: {{ section.settings.text_color }}; --altaeron-accent: {{ section.settings.accent_color }}; --altaeron-muted: {{ section.settings.muted_color }};">
  {%- if section.settings.show_packaging and has_packaging -%}
    <section id="altaeron-bring-home" class="altaeron-packaging altaeron-chapter" data-altaeron-chapter="Bring It Home" aria-labelledby="AltaeronPackagingTitle-{{ section.id }}">
      <div class="altaeron-packaging__copy">
        <p class="altaeron-kicker">05 / {{ section.settings.packaging_eyebrow | escape }}</p>
        <h2 id="AltaeronPackagingTitle-{{ section.id }}">{{ packaging_heading | default: section.settings.packaging_heading | escape }}</h2>
        <button
          type="button"
          class="altaeron-packaging__toggle"
          aria-expanded="true"
          aria-controls="AltaeronPackagingCopy-{{ section.id }} AltaeronPackagingMedia-{{ section.id }}"
          data-altaeron-packaging-toggle
        >
          <span class="visually-hidden">Toggle packaging details</span>
          <span aria-hidden="true"></span>
        </button>
        {%- if packaging_content != blank -%}<div id="AltaeronPackagingCopy-{{ section.id }}" class="altaeron-rte" data-altaeron-packaging-content>{{ packaging_content | metafield_tag }}</div>{%- endif -%}
      </div>
      {%- if packaging_image != blank -%}
        <div id="AltaeronPackagingMedia-{{ section.id }}" class="altaeron-packaging__media" data-altaeron-packaging-content>
          {{ packaging_image | image_url: width: 1800 | image_tag: loading: 'lazy', widths: '480, 720, 960, 1280, 1600, 1800', sizes: '(max-width: 767px) 100vw, 64vw', alt: packaging_image.alt }}
        </div>
      {%- endif -%}
    </section>
  {%- endif -%}

  {%- if section.settings.show_homes and lifestyle_gallery != blank -%}
    <section id="altaeron-homes" class="altaeron-homes altaeron-chapter" data-altaeron-chapter="Homes of Altaeron" aria-labelledby="AltaeronHomesTitle-{{ section.id }}">
      <header class="altaeron-section-heading">
        <p class="altaeron-kicker">06 / {{ section.settings.homes_eyebrow | escape }}</p>
        <h2 id="AltaeronHomesTitle-{{ section.id }}">{{ section.settings.homes_heading | escape }}</h2>
      </header>
      <div class="altaeron-homes__rail" role="region" aria-label="{{ section.settings.homes_heading | escape }}" tabindex="0">
        {%- for lifestyle_image in lifestyle_gallery limit: 10 -%}
          <figure class="altaeron-homes__item">
            {{ lifestyle_image | image_url: width: 1400 | image_tag: loading: 'lazy', widths: '360, 540, 720, 960, 1200, 1400', sizes: '(max-width: 767px) 82vw, 32vw', alt: lifestyle_image.alt }}
            {%- if lifestyle_image.alt != blank -%}<figcaption>{{ lifestyle_image.alt | escape }}</figcaption>{%- endif -%}
          </figure>
        {%- endfor -%}
      </div>
    </section>
  {%- endif -%}

  {%- if section.settings.show_stories and has_stories -%}
    <section id="altaeron-stories" class="altaeron-stories altaeron-chapter" data-altaeron-chapter="{{ stories_eyebrow | escape }}" aria-labelledby="AltaeronStoriesTitle-{{ section.id }}">
      <header class="altaeron-section-heading">
        <p class="altaeron-kicker">07 / {{ stories_eyebrow | escape }}</p>
        <h2 id="AltaeronStoriesTitle-{{ section.id }}"><span class="altaeron-desktop-only">{{ stories_heading | escape }}</span><span class="altaeron-mobile-only">{{ stories_mobile_heading | escape }}</span></h2>
        {%- if rating != blank and rating_count > 0 -%}
          <div class="altaeron-rating altaeron-rating--large" aria-label="{{ rating.rating }} out of {{ rating.scale_max }} stars, {{ rating_count }} reviews">
            <span aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</span><small>{{ rating.rating }} ({{ rating_count }})</small>
          </div>
        {%- endif -%}
      </header>

      {%- if show_judgeme_widget -%}
        <div class="altaeron-stories__slider" data-altaeron-judgeme-spotlight data-altaeron-review-slider hidden>
          <div class="altaeron-stories__controls" data-altaeron-review-controls hidden>
            <button type="button" class="altaeron-stories__control altaeron-stories__control--prev" data-altaeron-review-slide="prev" aria-label="Previous reviews">
              <span aria-hidden="true"></span>
            </button>
            <button type="button" class="altaeron-stories__control altaeron-stories__control--next" data-altaeron-review-slide="next" aria-label="Next reviews">
              <span aria-hidden="true"></span>
            </button>
          </div>
          <div
            class="altaeron-stories__track"
            data-altaeron-review-track
            role="region"
            aria-label="{{ stories_mobile_heading | default: stories_heading | escape }}"
            tabindex="0"
          ></div>
        </div>
        <div class="altaeron-judgeme" data-altaeron-judgeme data-product-id="{{ product.id }}">
          {%- render 'altaeron-judgeme-product-reviews' -%}
        </div>
      {%- endif -%}

      {%- if show_editorial_story and featured_review != blank -%}
        <div class="altaeron-stories__slider">
          <div
            class="altaeron-stories__track"
            role="region"
            aria-label="{{ stories_mobile_heading | default: stories_heading | escape }}"
            tabindex="0"
          >
            <article class="altaeron-featured-story">
              <div class="altaeron-featured-story__author">
                {%- if featured_review.avatar.value != blank -%}
                  {{ featured_review.avatar.value | image_url: width: 120 | image_tag: loading: 'lazy', widths: '60, 90, 120', sizes: '48px', alt: featured_review.customer_name.value }}
                {%- endif -%}
                <p><strong>{{ featured_review.customer_name.value | escape }}</strong>{% if featured_review.customer_location.value != blank %}<small>{{ featured_review.customer_location.value | escape }}</small>{% endif %}</p>
              </div>
              <blockquote>&ldquo;{{ featured_review.quote.value | escape }}&rdquo;</blockquote>
              {%- if featured_review.images.value != blank -%}
                <div class="altaeron-featured-story__images">
                  {%- for story_image in featured_review.images.value limit: 4 -%}
                    {{ story_image | image_url: width: 640 | image_tag: loading: 'lazy', widths: '180, 240, 360, 480, 640', sizes: '(max-width: 767px) 30vw, 14vw', alt: story_image.alt }}
                  {%- endfor -%}
                </div>
              {%- endif -%}
            </article>
          </div>
        </div>
      {%- endif -%}

      {%- for block in section.blocks -%}
        <div class="altaeron-review-app" {{ block.shopify_attributes }}>{% render block %}</div>
      {%- endfor -%}
    </section>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Altaeron story & reviews",
  "tag": "section",
  "class": "altaeron-template-section",
  "enabled_on": { "templates": ["product"] },
  "blocks": [{ "type": "@app" }],
  "settings": [
    { "type": "checkbox", "id": "show_packaging", "label": "Show packaging", "default": true },
    { "type": "checkbox", "id": "show_homes", "label": "Show lifestyle gallery", "default": true },
    { "type": "checkbox", "id": "show_stories", "label": "Show stories and reviews", "default": true },
    { "type": "color", "id": "background", "label": "Background", "default": "#050809" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#f4f0e8" },
    { "type": "color", "id": "muted_color", "label": "Muted text", "default": "#9a9b98" },
    { "type": "color", "id": "accent_color", "label": "Accent", "default": "#f3a316" },
    { "type": "text", "id": "packaging_eyebrow", "label": "Packaging eyebrow", "default": "Bring it home" },
    { "type": "text", "id": "packaging_heading", "label": "Packaging fallback heading", "default": "Bring A World Home." },
    { "type": "text", "id": "homes_eyebrow", "label": "Lifestyle eyebrow", "default": "Homes of Altaeron" },
    { "type": "text", "id": "homes_heading", "label": "Lifestyle heading", "default": "See How It Lives In Real Homes." },
    { "type": "text", "id": "stories_eyebrow", "label": "Review eyebrow", "default": "Stories from dreamers" },
    { "type": "text", "id": "stories_heading", "label": "Review heading", "default": "More Than A Product. A Piece Of Another World." },
    { "type": "text", "id": "stories_mobile_heading", "label": "Mobile review heading", "default": "Stories From Dreamers." },
    { "type": "checkbox", "id": "show_judgeme_widget", "label": "Show Judge.me product reviews", "default": true },
    { "type": "checkbox", "id": "show_editorial_story", "label": "Show editorial story fallback", "default": false }
  ],
  "presets": [{ "name": "Altaeron story & reviews" }]
}
{% endschema %}
