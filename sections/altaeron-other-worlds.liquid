{%- liquid
  assign related_collection = product.metafields.custom.related_realm.value
  assign fallback_collection = product.collections.first
  assign limit = section.settings.limit
-%}

{%- if section.settings.show_section -%}
{{ 'altaeron-product.css' | asset_url | stylesheet_tag }}
<script src="{{ 'product-recommendations.js' | asset_url }}" defer="defer"></script>

<section id="altaeron-other-worlds" class="altaeron-worlds altaeron-surface altaeron-chapter" data-altaeron-chapter="Other Worlds Await" aria-labelledby="AltaeronWorldsTitle-{{ section.id }}" style="--altaeron-bg: {{ section.settings.background }}; --altaeron-text: {{ section.settings.text_color }}; --altaeron-accent: {{ section.settings.accent_color }}; --altaeron-muted: {{ section.settings.muted_color }};">
  <header class="altaeron-section-heading">
    <p class="altaeron-kicker">09 / {{ section.settings.eyebrow | escape }}</p>
    <h2 id="AltaeronWorldsTitle-{{ section.id }}">{{ section.settings.heading | escape }}</h2>
  </header>

  {%- if related_collection != blank -%}
    <div class="altaeron-worlds__grid">
      {%- assign shown = 0 -%}
      {%- for related_product in related_collection.products -%}
        {%- unless related_product.id == product.id -%}
          {% render 'altaeron-related-world-card', product: related_product %}
          {%- assign shown = shown | plus: 1 -%}
          {%- if shown >= limit -%}{%- break -%}{%- endif -%}
        {%- endunless -%}
      {%- endfor -%}
    </div>
  {%- else -%}
    <product-recommendations class="altaeron-worlds__recommendations" data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ limit }}">
      {%- if recommendations.performed and recommendations.products_count > 0 -%}
        <div class="altaeron-worlds__grid">
          {%- for related_product in recommendations.products limit: limit -%}
            {% render 'altaeron-related-world-card', product: related_product %}
          {%- endfor -%}
        </div>
      {%- elsif recommendations.performed and fallback_collection != blank -%}
        <div class="altaeron-worlds__grid">
          {%- assign shown = 0 -%}
          {%- for related_product in fallback_collection.products -%}
            {%- unless related_product.id == product.id -%}
              {% render 'altaeron-related-world-card', product: related_product %}
              {%- assign shown = shown | plus: 1 -%}
              {%- if shown >= limit -%}{%- break -%}{%- endif -%}
            {%- endunless -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </product-recommendations>
  {%- endif -%}
</section>
{%- endif -%}

{% schema %}
{
  "name": "Altaeron other worlds",
  "tag": "section",
  "class": "altaeron-template-section altaeron-template-section--last",
  "enabled_on": { "templates": ["product"] },
  "settings": [
    { "type": "checkbox", "id": "show_section", "label": "Show section", "default": true },
    { "type": "color", "id": "background", "label": "Background", "default": "#050809" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#f4f0e8" },
    { "type": "color", "id": "muted_color", "label": "Muted text", "default": "#9a9b98" },
    { "type": "color", "id": "accent_color", "label": "Accent", "default": "#f3a316" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Other worlds await" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Other Worlds Await." },
    { "type": "range", "id": "limit", "label": "Maximum products", "min": 2, "max": 8, "step": 1, "default": 4 }
  ],
  "presets": [{ "name": "Altaeron other worlds" }]
}
{% endschema %}
