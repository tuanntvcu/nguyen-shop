{{ 'altaeron-product.css' | asset_url | stylesheet_tag }}

<footer class="altaeron-product-footer altaeron-surface" aria-label="Altaeron footer" style="--altaeron-bg:#050809;--altaeron-text:#f4f0e8;--altaeron-accent:#f3a316;--altaeron-muted:#9a9b98;">
  <aside class="altaeron-product-footer__trust" aria-label="Store assurances">
    {% render 'altaeron-trust-items' %}
  </aside>

  <div class="altaeron-product-footer__main">
    <div class="altaeron-product-footer__brand">
      {% render 'altaeron-brand', text: shop.name, class: 'altaeron-brand--footer' %}
      <p>We preserve worlds in resin.</p>
      <div class="altaeron-product-footer__socials" aria-label="Social links">
        {%- if settings.social_instagram_link != blank -%}<a href="{{ settings.social_instagram_link }}" aria-label="Instagram">{% render 'icon-instagram' %}</a>{%- endif -%}
        {%- if settings.social_facebook_link != blank -%}<a href="{{ settings.social_facebook_link }}" aria-label="Facebook">{% render 'icon-facebook' %}</a>{%- endif -%}
        {%- if settings.social_youtube_link != blank -%}<a href="{{ settings.social_youtube_link }}" aria-label="YouTube">{% render 'icon-youtube' %}</a>{%- endif -%}
        {%- if settings.social_tiktok_link != blank -%}<a href="{{ settings.social_tiktok_link }}" aria-label="TikTok">{% render 'icon-tiktok' %}</a>{%- endif -%}
        {%- if settings.social_pinterest_link != blank -%}<a href="{{ settings.social_pinterest_link }}" aria-label="Pinterest">{% render 'icon-pinterest' %}</a>{%- endif -%}
      </div>
    </div>

    <nav class="altaeron-product-footer__links" aria-label="Footer navigation">
      {%- assign custom_page = pages['custom'] -%}
      {%- assign story_page = pages['our-story'] -%}
      {%- assign support_page = pages['contact'] -%}
      <details><summary>Collections <span>+</span></summary><a href="{{ routes.collections_url }}">All Collections</a><a href="/collections/dragon-series">Dragon Series</a><a href="/collections/nature-series">Nature Series</a></details>
      <details><summary>Best Sellers <span>+</span></summary><a href="/collections/best-sellers">Best Sellers</a></details>
      <details><summary>Custom <span>+</span></summary><a href="{% if custom_page != blank %}{{ custom_page.url }}{% else %}{{ routes.root_url }}{% endif %}">Custom Order</a><a href="{% if custom_page != blank %}{{ custom_page.url }}{% else %}{{ routes.root_url }}{% endif %}">How It Works</a></details>
      <details><summary>Our Story <span>+</span></summary><a href="{% if story_page != blank %}{{ story_page.url }}{% else %}{{ routes.root_url }}{% endif %}">About Altaeron</a><a href="{% if story_page != blank %}{{ story_page.url }}{% else %}{{ routes.root_url }}{% endif %}">Craftsmanship</a></details>
      <details><summary>Journal <span>+</span></summary><a href="{{ routes.root_url }}blogs/news">Journal</a></details>
      <details><summary>Support <span>+</span></summary><a href="{% if support_page != blank %}{{ support_page.url }}{% else %}{{ routes.root_url }}{% endif %}">Contact</a><a href="#altaeron-guide">FAQ</a></details>
    </nav>

    <div class="altaeron-product-footer__newsletter">
      <h2>Join The Altaeron Universe</h2>
      <p>Stories. New worlds. Early access.</p>
      {% render 'newsletter-form', custom_id: section.id %}
    </div>
  </div>

  <div class="altaeron-product-footer__legal">
    <small>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</small>
    <div><a href="{{ shop.privacy_policy.url }}">Privacy Policy</a><a href="{{ shop.terms_of_service.url }}">Terms of Service</a></div>
  </div>
</footer>

{% schema %}
{
  "name": "Altaeron product footer",
  "tag": "section",
  "class": "altaeron-template-section altaeron-template-section--footer",
  "enabled_on": { "templates": ["product"] },
  "settings": [
    { "type": "text", "id": "trust_1_label", "label": "Trust item 1", "default": "Free shipping" },
    { "type": "text", "id": "trust_1_text", "label": "Trust item 1 detail", "default": "On orders over $99" },
    { "type": "text", "id": "trust_2_label", "label": "Trust item 2", "default": "30-day returns" },
    { "type": "text", "id": "trust_2_text", "label": "Trust item 2 detail", "default": "Hassle-free returns" },
    { "type": "text", "id": "trust_3_label", "label": "Trust item 3", "default": "Secure payment" },
    { "type": "text", "id": "trust_3_text", "label": "Trust item 3 detail", "default": "100% protected" },
    { "type": "text", "id": "trust_4_label", "label": "Trust item 4", "default": "1 year warranty" },
    { "type": "text", "id": "trust_4_text", "label": "Trust item 4 detail", "default": "We've got you covered" }
  ],
  "presets": [{ "name": "Altaeron product footer" }]
}
{% endschema %}
