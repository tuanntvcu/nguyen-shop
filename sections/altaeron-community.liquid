{{ 'section-altaeron-home.css' | asset_url | stylesheet_tag }}

<section class="altaeron-section altaeron-community" data-section-id="{{ section.id }}">
  <div class="page-width altaeron-community__inner">
    <div>
      {%- if section.settings.eyebrow != blank -%}
        <p class="altaeron-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="altaeron-heading altaeron-heading--section">{{ section.settings.heading | escape | newline_to_br }}</h2>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <div class="altaeron-text">{{ section.settings.text }}</div>
      {%- endif -%}
      {%- if section.settings.button_label != blank -%}
        <div class="altaeron-community__actions">
          <a
            class="altaeron-button altaeron-button--secondary"
            {% if section.settings.button_link != blank %}
              href="{{ section.settings.button_link }}"
            {% else %}
              role="link" aria-disabled="true"
            {% endif %}
          >
            {{ section.settings.button_label }}
          </a>
        </div>
      {%- endif -%}
    </div>
    <div class="altaeron-community__gallery">
      {%- for block in section.blocks -%}
        <div class="altaeron-community__image" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {{
              block.settings.image
              | image_url: width: 700
              | image_tag:
                loading: 'lazy',
                widths: '260, 420, 560, 700',
                sizes: '(max-width: 767px) 100vw, 16vw'
            }}
          {%- else -%}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg altaeron-placeholder' }}
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Altaeron community",
  "tag": "section",
  "class": "section",
  "max_blocks": 8,
  "disabled_on": {
    "groups": ["header", "footer", "custom.overlay"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "JOIN OUR COMMUNITY"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "50,000+ ANGLERS WORLDWIDE.\nONE COMMUNITY."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Share your catches. Get featured. Be part of the Altaeron crew.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "FOLLOW @ALTAERONFISHING"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Gallery image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Altaeron community",
      "blocks": [
        {
          "type": "image"
        },
        {
          "type": "image"
        },
        {
          "type": "image"
        },
        {
          "type": "image"
        }
      ]
    }
  ]
}
{% endschema %}
