{%- liquid
  assign current_variant = variant | default: product.selected_or_first_available_variant
  assign sticky_image = current_variant.featured_media.preview_image | default: product.featured_media.preview_image
  assign compare_at_price = current_variant.compare_at_price
  assign price = current_variant.price
  assign add_to_cart_label = 'products.product.add_to_cart' | t
  assign sold_out_label = 'products.product.sold_out' | t
  assign unavailable_label = 'products.product.unavailable' | t
  assign loading_label = 'Adding...'
  assign observe_target = observe_selector | default: '.product__block--buy_buttons'
-%}

<mobile-product-sticky-atc
  class="mobile-product-sticky-atc{% if class != blank %} {{ class }}{% endif %}"
  data-product-id="{{ product.id }}"
  data-section-id="{{ section.id }}"
  data-product-title="{{ product.title | escape }}"
  data-observe-selector="{{ observe_target | escape }}"
  data-add-label="{{ add_to_cart_label | escape }}"
  data-loading-label="{{ loading_label | escape }}"
  data-sold-out-label="{{ sold_out_label | escape }}"
  data-unavailable-label="{{ unavailable_label | escape }}"
  style="--mobile-sticky-bg: {{ section.settings.background | default: '#050809' }}; --mobile-sticky-text: {{ section.settings.text_color | default: '#f4f0e8' }}; --mobile-sticky-muted: {{ section.settings.muted_color | default: '#a9a39a' }}; --mobile-sticky-accent: {{ section.settings.accent_color | default: '#f3a316' }};"
  hidden
  aria-hidden="true"
>
  <div class="mobile-product-sticky-atc__product">
    <div class="mobile-product-sticky-atc__thumb" aria-hidden="true">
      {%- if sticky_image != blank -%}
        {{
          sticky_image
          | image_url: width: 144
          | image_tag:
            loading: 'lazy',
            fetchpriority: 'low',
            widths: '72, 108, 144',
            sizes: '54px',
            alt: ''
        }}
      {%- endif -%}
    </div>
    <div class="mobile-product-sticky-atc__copy">
      <p class="mobile-product-sticky-atc__title" data-sticky-title>{{ product.title | escape }}</p>
      <p class="mobile-product-sticky-atc__variant" data-sticky-variant-title{% if product.has_only_default_variant %} hidden{% endif %}>
        {%- unless product.has_only_default_variant -%}{{ current_variant.title | escape }}{%- endunless -%}
      </p>
      <div class="mobile-product-sticky-atc__prices" data-sticky-price-region aria-live="polite">
        <span class="mobile-product-sticky-atc__price" data-sticky-price>{{ price | money }}</span>
        <s
          class="mobile-product-sticky-atc__compare"
          data-sticky-compare-price
          {% unless compare_at_price > price %}
            hidden
          {% endunless %}
        >
          {{- compare_at_price | money -}}
        </s>
      </div>
    </div>
  </div>
  <button
    type="button"
    class="mobile-product-sticky-atc__button"
    data-sticky-submit
    {% unless current_variant.available %}
      disabled
    {% endunless %}
    aria-label="{{ add_to_cart_label | escape }}: {{ product.title | escape }}{% unless product.has_only_default_variant %}, {{ current_variant.title | escape }}{% endunless %}"
  >
    {%- if current_variant.available -%}{{ add_to_cart_label }}{%- else -%}{{ sold_out_label }}{%- endif -%}
  </button>
  <p class="mobile-product-sticky-atc__error" data-sticky-error role="status" aria-live="polite" hidden></p>
  <script type="application/json" data-mobile-sticky-variants>
    {{ product.variants | json }}
  </script>
</mobile-product-sticky-atc>
