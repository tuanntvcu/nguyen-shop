{%- comment -%}
  Compact, decorative icon set for the Altaeron exhibition section.
  Parameters: name, class, label
{%- endcomment -%}
{%- assign icon_class = class | default: 'altaeron-icon' -%}
<svg class="{{ icon_class }}" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
  {%- case name -%}
    {%- when 'shipping' -%}
      <path d="M3 6.5h11v10H3zM14 10h3.5l3 3v3.5H14zM6.5 19a2 2 0 1 0 0-4 2 2 0 0 0 0 4ZM17.5 19a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z"/>
    {%- when 'shield' -%}
      <path d="M12 2.8 19 6v5.2c0 4.5-2.9 8.3-7 10-4.1-1.7-7-5.5-7-10V6l7-3.2Z"/><path d="m8.8 11.6 2.1 2.1 4.5-4.7"/>
    {%- when 'globe' -%}
      <circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3c2.3 2.5 3.5 5.5 3.5 9S14.3 18.5 12 21M12 3c-2.3 2.5-3.5 5.5-3.5 9S9.7 18.5 12 21"/>
    {%- when 'lock' -%}
      <rect x="4" y="10" width="16" height="11" rx="2"/><path d="M8 10V7a4 4 0 0 1 8 0v3M12 14v3"/>
    {%- when 'returns' -%}
      <path d="M4.4 7.4A9 9 0 1 1 3 12M4.4 7.4V3m0 4.4H9"/><path d="M12 7v5l3 2"/>
    {%- when 'spark' -%}
      <path d="m12 2 1.8 6.2L20 10l-6.2 1.8L12 18l-1.8-6.2L4 10l6.2-1.8L12 2Z"/>
    {%- when 'cart' -%}
      <path d="M3 4h2l2 11h10l2-7H6M9 20a1 1 0 1 0 0-2 1 1 0 0 0 0 2ZM17 20a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z"/>
    {%- when 'menu' -%}
      <path d="M4 7h16M4 12h16M4 17h16"/>
    {%- when 'search' -%}
      <circle cx="10.5" cy="10.5" r="6.5"/><path d="m15.5 15.5 4.5 4.5"/>
    {%- when 'story' -%}
      <path d="M4 4.5c3-1 5.7-.5 8 1.5v14c-2.3-2-5-2.5-8-1.5v-14ZM20 4.5c-3-1-5.7-.5-8 1.5v14c2.3-2 5-2.5 8-1.5v-14Z"/>
    {%- when 'grid' -%}
      <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
    {%- else -%}
      <path d="M12 2.5 15 9l6.5 3-6.5 3-3 6.5L9 15l-6.5-3L9 9l3-6.5Z"/>
  {%- endcase -%}
</svg>
