{%- comment -%}Merchant settings win; verified store policies provide safe fallbacks.{%- endcomment -%}
{%- assign trust_icons = 'shipping|returns|payment|warranty' | split: '|' -%}
<ul class="altaeron-trust" role="list">
  {%- for index in (1..4) -%}
    {%- capture label_key -%}trust_{{ index }}_label{%- endcapture -%}
    {%- capture text_key -%}trust_{{ index }}_text{%- endcapture -%}
    {%- assign trust_label = section.settings[label_key] -%}
    {%- assign trust_text = section.settings[text_key] -%}
    {%- assign trust_url = blank -%}
    {%- case forloop.index -%}
      {%- when 1 -%}
        {%- if shop.shipping_policy.body != blank -%}
          {%- assign trust_url = shop.shipping_policy.url -%}
          {%- if trust_label == blank -%}{%- assign trust_label = 'Shipping options' -%}{%- endif -%}
          {%- if trust_text == blank -%}{%- assign trust_text = 'Calculated at checkout' -%}{%- endif -%}
        {%- endif -%}
      {%- when 2 -%}
        {%- if shop.refund_policy.body != blank -%}
          {%- assign trust_url = shop.refund_policy.url -%}
          {%- if trust_label == blank -%}{%- assign trust_label = '30-day returns' -%}{%- endif -%}
          {%- if trust_text == blank -%}{%- assign trust_text = 'See return policy' -%}{%- endif -%}
        {%- endif -%}
      {%- when 3 -%}
        {%- if trust_label == blank -%}{%- assign trust_label = 'Secure checkout' -%}{%- endif -%}
        {%- if trust_text == blank -%}{%- assign trust_text = 'Shopify powered' -%}{%- endif -%}
      {%- when 4 -%}
        {%- assign warranty_page = pages['altaeron-limited-warranty'] -%}
        {%- if warranty_page != blank -%}
          {%- assign trust_url = warranty_page.url -%}
          {%- if trust_label == blank -%}{%- assign trust_label = '1-year warranty' -%}{%- endif -%}
          {%- if trust_text == blank -%}{%- assign trust_text = 'Limited coverage' -%}{%- endif -%}
        {%- endif -%}
    {%- endcase -%}
    {%- if trust_label != blank -%}
      <li class="altaeron-trust__item">
        <span class="altaeron-trust__icon" aria-hidden="true" data-icon="{{ trust_icons[forloop.index0] }}">
          {%- case forloop.index -%}
            {%- when 1 -%}
              <svg viewBox="0 0 24 24"><path d="M3 6h11v11H3zM14 10h4l3 3v4h-7zM7 20a2 2 0 1 0 0-4 2 2 0 0 0 0 4Zm10 0a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z"/></svg>
            {%- when 2 -%}
              <svg viewBox="0 0 24 24"><path d="M4 9a8 8 0 1 1 1 8M4 9V4m0 5h5"/></svg>
            {%- when 3 -%}
              <svg viewBox="0 0 24 24"><rect x="3" y="6" width="18" height="13" rx="2"/><path d="M3 10h18m-5 5h2"/></svg>
            {%- else -%}
              <svg viewBox="0 0 24 24"><path d="m12 3 2.3 2 3-.2.7 3 2.5 1.7-1.2 2.8 1.2 2.8-2.5 1.7-.7 3-3-.2-2.3 2-2.3-2-3 .2-.7-3-2.5-1.7 1.2-2.8-1.2-2.8L6 7.8l.7-3 3 .2z"/><path d="m9 12 2 2 4-4"/></svg>
          {%- endcase -%}
        </span>
        {%- if trust_url != blank -%}<a class="altaeron-trust__link" href="{{ trust_url }}">{%- else -%}<span>{%- endif -%}
          <strong>{{ trust_label | escape }}</strong>{% if trust_text != blank %}<small>{{ trust_text | escape }}</small>{% endif %}
        {%- if trust_url != blank -%}</a>{%- else -%}</span>{%- endif -%}
      </li>
    {%- endif -%}
  {%- endfor -%}
</ul>
